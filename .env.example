##############################################################################
# Copia este fichero a .env.local y rellena los valores. .env.local NO se
# versiona (Git lo ignora), así que tus secretos no acaban en el repositorio
# y el .env versionado del proyecto queda intacto.
#
# Indica a Docker Compose que use este fichero exportándolo una vez por sesión:
#   export COMPOSE_ENV_FILES=.env.local
#   docker compose up -d
# (equivale a añadir --env-file .env.local a cada comando docker compose).
#
# Genera los secretos con:  php -r 'echo bin2hex(random_bytes(32));'
##############################################################################

# ── Symfony ───────────────────────────────────────────────────────────────────
APP_SECRET=cambia_esto_por_una_clave_aleatoria_de_64_hex

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_PASSWORD=cambia_esto_por_una_contrasena_segura

# ── Mercure (sincronización en vivo) ──────────────────────────────────────────
# Secreto para firmar los JWT del hub Mercure embebido. Genera uno aleatorio
# distinto de APP_SECRET. El hub va dentro de FrankenPHP; no hay contenedor aparte.
MERCURE_JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_64_hex

# ── Servidor ──────────────────────────────────────────────────────────────────
# Solo HTTP en el puerto 80:
SERVER_NAME=:80
HTTP_PORT=80
HTTPS_PORT=443

# Para HTTPS automático con Let's Encrypt, usa tu dominio:
# SERVER_NAME=gestconv.tudominio.es
# DEFAULT_URI=https://gestconv.tudominio.es

DEFAULT_URI=http://localhost

# ── Configuración de la aplicación ────────────────────────────────────────────
APP_EXTERNAL_ENABLED=true
APP_EXTERNAL_URL=https://seneca.juntadeandalucia.es/seneca/jsp/ComprobarUsuarioExt.jsp
APP_EXTERNAL_URL_FORCE_SECURITY=true

# ── Registro de actividad ─────────────────────────────────────────────────────
# Activa o desactiva el registro de auditoría de acciones de usuario.
# Desactívalo en el despliegue binario nativo si no necesitas auditoría.
APP_LOG=true
# Días que se conservan las entradas antes de que la limpieza semanal las borre.
APP_LOG_RETENTION_DAYS=90

# ── Proxy inverso ─────────────────────────────────────────────────────────────
# Si la aplicación está detrás de un proxy inverso (nginx, Caddy, balanceador…),
# indica aquí su IP para que el registro muestre la IP real del usuario.
# SYMFONY_TRUSTED_PROXIES=127.0.0.1

# ── Datos de demostración ─────────────────────────────────────────────────────
# Establece a "true" para cargar automáticamente usuarios, centros, empresas y
# estancias de prueba en cada arranque. ⚠️ Borra todos los datos existentes.
# Ver DEMO.md para los usuarios y contraseñas disponibles.
LOAD_FIXTURES=false

# ── Notificaciones por email ──────────────────────────────────────────────────
# Las notificaciones están desactivadas por defecto (null://null descarta los mensajes).
# Configura un transporte real para activarlas, p. ej. MAILER_DSN=smtp://usuario:clave@servidor:587
# IMPORTANTE: en producción configura también DEFAULT_URI (más arriba) para que
# los enlaces de los emails apunten a la URL pública de la aplicación.
MAILER_DSN=null://null
# Dirección remitente de los emails automáticos
MAILER_FROM=no-responder@example.com
