DirectoryIndex index.php

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI}::$0 ^(/.+)/(.*)::\2$
    RewriteRule .* - [E=BASE:%1]

    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%0]

    RewriteCond %{ENV:REDIRECT_STATUS} =""
    RewriteRule ^index\.php(?:/(.*)|$) %{ENV:BASE}/$1 [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ %{ENV:BASE}/index.php [L]
</IfModule>

<IfModule !mod_rewrite.c>
    <IfModule mod_alias.c>
        RedirectMatch 307 ^/$ /index.php/
    </IfModule>
</IfModule>

# Cabeceras de seguridad de base. La CSP no se aplica aquí (se afinará aparte:
# UX-Live, Quill y TomSelect requieren validación cuidadosa de los orígenes).
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Compresión de respuestas de texto. Caddy (Docker y binario nativo) ya
# comprime con "encode zstd br gzip"; aquí se replica para Apache/Plesk.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript \
        application/javascript application/json image/svg+xml font/woff2 font/woff
</IfModule>

# Caché de ficheros estáticos. public/assets/ lo genera AssetMapper con el
# hash del contenido en el nombre de fichero (p. ej. app-FWOVdy1.js): un
# cambio de contenido siempre implica una URL nueva, así que es seguro
# cachear "para siempre". public/static/ (favicons, logo, fuentes) no lleva
# hash, así que usa una duración moderada en vez de "immutable".
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/assets/#">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
    <ElseIf "%{REQUEST_URI} =~ m#^/static/#">
        Header set Cache-Control "public, max-age=2592000"
    </ElseIf>
</IfModule>
