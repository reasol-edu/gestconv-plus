{% if canSeeContact %}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs"{{ canEditContact ? ' data-controller="dialog"' : '' }}>
        <div class="border-b border-gray-100 px-6 py-3.5 flex items-center justify-between gap-3">
            <h2 class="text-sm font-semibold text-gray-800">{{ 'student.show.contact'|trans({}, 'admin') }}</h2>
            {% if canEditContact %}
                <button type="button"
                        data-action="dialog#open"
                        class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-2.5 py-1 text-xs font-medium
                               text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                    {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                    {{ 'student.show.edit_contact'|trans({}, 'admin') }}
                </button>
            {% endif %}
        </div>
        <div class="px-6 py-4 grid grid-cols-1 gap-4 sm:grid-cols-2 text-sm">
            {% if student.tutorName1 %}
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'student.show.tutor1'|trans({}, 'admin') }}</p>
                    <p class="text-gray-900">{{ student.tutorName1 }}</p>
                    {% if student.tutorEmail1 %}<p class="text-gray-500">{{ student.tutorEmail1 }}</p>{% endif %}
                </div>
            {% endif %}
            {% if student.tutorName2 %}
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'student.show.tutor2'|trans({}, 'admin') }}</p>
                    <p class="text-gray-900">{{ student.tutorName2 }}</p>
                    {% if student.tutorEmail2 %}<p class="text-gray-500">{{ student.tutorEmail2 }}</p>{% endif %}
                </div>
            {% endif %}
            {% set phones = [
                {number: student.contactPhone1, notes: student.contactPhone1Notes},
                {number: student.contactPhone2, notes: student.contactPhone2Notes},
                {number: student.contactPhone3, notes: student.contactPhone3Notes},
            ]|filter(p => p.number) %}
            {% if phones|length > 0 %}
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'student.show.phones'|trans({}, 'admin') }}</p>
                    {% for phone in phones %}
                        <p class="text-gray-900">
                            {{ phone.number }}
                            {% if phone.notes %}<span class="text-gray-500">— {{ phone.notes }}</span>{% endif %}
                        </p>
                    {% endfor %}
                </div>
            {% endif %}
            {% if student.details %}
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'student.show.details'|trans({}, 'admin') }}</p>
                    <p class="text-gray-700 whitespace-pre-wrap">{{ student.details }}</p>
                </div>
            {% endif %}
            {% if not student.tutorName1 and not student.tutorName2 and phones|length == 0 and not student.details %}
                <p class="text-gray-400 text-xs col-span-full">{{ 'student.show.contact_empty'|trans({}, 'admin') }}</p>
            {% endif %}
        </div>

        {% if canEditContact %}
            <dialog data-dialog-target="dialog"
                    class="m-auto w-full max-w-lg rounded-2xl border border-gray-200 p-0 backdrop:bg-black/50">
                <div class="p-6">
                    <div class="flex items-start justify-between gap-4 mb-4">
                        <p class="text-sm font-semibold text-gray-900">{{ 'student.show.edit_contact'|trans({}, 'admin') }}</p>
                        <button type="button"
                                data-action="dialog#close"
                                aria-label="{{ 'ui.close'|trans }}"
                                class="shrink-0 text-gray-400 hover:text-gray-600">
                            {{ ux_icon('heroicons:x-mark', {class: 'h-5 w-5'}) }}
                        </button>
                    </div>

                    <form method="post" action="{{ path('app_students_edit_contact', {id: student.id}) }}" class="space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('edit_contact_' ~ student.id) }}">

                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">{{ 'student.field.tutor_name_1'|trans({}, 'admin') }}</label>
                                <input type="text" name="tutorName1" value="{{ student.tutorName1 }}"
                                       class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">{{ 'student.field.tutor_email_1'|trans({}, 'admin') }}</label>
                                <input type="email" name="tutorEmail1" value="{{ student.tutorEmail1 }}"
                                       class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">{{ 'student.field.tutor_name_2'|trans({}, 'admin') }}</label>
                                <input type="text" name="tutorName2" value="{{ student.tutorName2 }}"
                                       class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">{{ 'student.field.tutor_email_2'|trans({}, 'admin') }}</label>
                                <input type="email" name="tutorEmail2" value="{{ student.tutorEmail2 }}"
                                       class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                            {% for i in 1..3 %}
                                <div>
                                    <label class="block text-xs font-medium text-gray-700 mb-1">{{ ('student.field.contact_phone_' ~ i)|trans({}, 'admin') }}</label>
                                    <input type="text" name="contactPhone{{ i }}" value="{{ attribute(student, 'contactPhone' ~ i) }}"
                                           class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                                    <input type="text" name="contactPhone{{ i }}Notes" value="{{ attribute(student, 'contactPhone' ~ i ~ 'Notes') }}"
                                           placeholder="{{ ('student.field.contact_phone_' ~ i ~ '_notes')|trans({}, 'admin') }}"
                                           class="mt-1.5 block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">
                                </div>
                            {% endfor %}
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">{{ 'student.field.details'|trans({}, 'admin') }}</label>
                            <textarea name="details" rows="3"
                                      class="block w-full rounded-lg border border-gray-200 py-2 px-3 text-sm focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20">{{ student.details }}</textarea>
                        </div>

                        <div class="flex justify-end gap-2 pt-2">
                            <button type="button" data-action="dialog#close"
                                    class="inline-flex items-center rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                                {{ 'student.cancel'|trans({}, 'admin') }}
                            </button>
                            <button type="submit"
                                    class="inline-flex items-center rounded-lg bg-forest-600 px-4 py-2 text-sm font-semibold text-white hover:bg-forest-700 transition-colors">
                                {{ 'student.save'|trans({}, 'admin') }}
                            </button>
                        </div>
                    </form>
                </div>
            </dialog>
        {% endif %}
    </div>
{% endif %}
