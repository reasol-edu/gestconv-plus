<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DejaVu Sans', Arial, sans-serif;
        font-size: 9pt;
        color: #1f2937;
        line-height: 1.35;
    }

    /* ── Cabecera de página (no se reduce) ── */
    .page-header {
        border-bottom: 2px solid #576490;
        padding-bottom: 10px;
        margin-bottom: 14px;
    }
    .page-header h1 {
        font-size: 17pt;
        font-weight: bold;
        color: #111827;
    }
    .page-header .subtitle {
        font-size: 11pt;
        color: #374151;
        margin-top: 3px;
    }
    .page-header .meta {
        font-size: 9.5pt;
        color: #6b7280;
        margin-top: 2px;
    }
    .page-header .centre-info {
        font-size: 10pt;
        color: #576490;
        margin-top: 4px;
        font-weight: bold;
        letter-spacing: 0.3pt;
    }

    /* ── Secciones ── */
    .section-title {
        font-size: 9.5pt;
        font-weight: bold;
        color: #2b3350;
        text-transform: uppercase;
        letter-spacing: 0.4pt;
        border-bottom: 1px solid #c9cad9;
        padding-bottom: 4px;
        margin-bottom: 8px;
        margin-top: 15px;
    }
    .subsection-title {
        font-size: 9pt;
        font-weight: bold;
        color: #3e4a6e;
        background-color: #f0f0ff;
        border-left: 3px solid #677dae;
        padding: 4px 8px;
        margin-bottom: 6px;
        margin-top: 10px;
    }

    /* ── Texto de descripción / observaciones (HTML saneado) ── */
    .prose-block {
        margin-bottom: 7px;
    }
    .prose-block p {
        margin-bottom: 5px;
    }

    /* ── Tablas de datos ── */
    table.data-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
        font-size: 8pt;
    }
    table.data-table thead {
        display: table-header-group;
    }
    table.data-table thead tr {
        background-color: #3e4a6e;
    }
    table.data-table thead th {
        padding: 5px 7px;
        text-align: left;
        vertical-align: middle;
        font-weight: bold;
        font-size: 7.5pt;
        text-transform: uppercase;
        letter-spacing: 0.3pt;
        color: #ffffff;
    }
    table.data-table tbody tr {
        page-break-inside: avoid;
    }
    table.data-table tbody tr:nth-child(even) {
        background-color: #f7f7fb;
    }
    table.data-table tbody tr:nth-child(odd) {
        background-color: #ffffff;
    }
    table.data-table tbody td {
        padding: 5px 7px;
        border-bottom: 1px solid #e5e6ee;
        vertical-align: top;
        line-height: 1.25;
        color: #1f2937;
    }

    /* ── Texto secundario dentro de una celda ── */
    .cell-sub {
        color: #6b7280;
        font-size: 7.5pt;
    }

    /* ── Badges ──
       mPDF no aplica border-radius a elementos inline, así que las píldoras
       quedan rectangulares (varias en la misma línea); se compensa con más
       padding para que el color no quede pegado al texto. */
    .badge {
        display: inline-block;
        padding: 3px 9px;
        margin: 0 4px 4px 0;
        font-size: 7.5pt;
        font-weight: 600;
        letter-spacing: 0.2pt;
        color: #1f2937;
    }
    .badge-green  { background-color: #dcfce7; color: #15803d; }
    .badge-amber  { background-color: #fef3c7; color: #92400e; }
    .badge-red    { background-color: #fee2e2; color: #b91c1c; }
    .badge-blue   { background-color: #dbeafe; color: #1d4ed8; }
    .badge-gray   { background-color: #f3f4f6; color: #4b5563; }
    .badge-purple { background-color: #d1d2f9; color: #2b3350; }

    /* ── Pie de página (no se reduce) ── */
    .pdf-footer {
        font-size: 8.5pt;
        color: #6b7280;
        text-align: right;
        border-top: 1px solid #e5e7eb;
        padding-top: 4px;
    }
</style>
