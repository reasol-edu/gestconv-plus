<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DejaVu Sans', Arial, sans-serif;
        font-size: 6.5pt;
        color: #1f2937;
        line-height: 1.35;
    }

    /* ── Cabecera de página (no se reduce) ── */
    .page-header {
        border-bottom: 2px solid #5b21b6;
        padding-bottom: 10px;
        margin-bottom: 14px;
    }
    .page-header h1 {
        font-size: 15pt;
        font-weight: bold;
        color: #111827;
    }
    .page-header .subtitle {
        font-size: 9pt;
        color: #374151;
        margin-top: 3px;
    }
    .page-header .meta {
        font-size: 8pt;
        color: #6b7280;
        margin-top: 2px;
    }
    .page-header .centre-info {
        font-size: 8.5pt;
        color: #5b21b6;
        margin-top: 4px;
        font-weight: bold;
        letter-spacing: 0.3pt;
    }

    /* ── Secciones ── */
    h2 {
        font-size: 7pt;
        font-weight: bold;
        color: #3b0764;
        text-transform: uppercase;
        letter-spacing: 0.4pt;
        border-bottom: 1px solid #c4b5fd;
        padding-bottom: 3px;
        margin-bottom: 7px;
        margin-top: 13px;
    }
    h3 {
        font-size: 6.5pt;
        font-weight: bold;
        color: #4c1d95;
        background-color: #f3f0fb;
        border-left: 3px solid #7c3aed;
        padding: 3px 7px;
        margin-bottom: 5px;
        margin-top: 9px;
    }

    /* ── Rejilla de estadísticas ── */
    .stats-grid {
        width: 100%;
        border-collapse: separate;
        border-spacing: 5px 0;
        margin-bottom: 13px;
    }
    .stats-grid td {
        width: 25%;
        border: 1px solid #e5e7eb;
        border-top: 2px solid #7c3aed;
        padding: 7px 9px;
        text-align: center;
        vertical-align: middle;
        background-color: #fbfaff;
    }
    .stats-grid .stat-value {
        font-size: 10pt;
        font-weight: bold;
        color: #4c1d95;
        display: block;
    }
    .stats-grid .stat-label {
        font-size: 5pt;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.3pt;
        display: block;
        margin-top: 2px;
    }

    /* ── Tablas de datos ── */
    table.data-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 9px;
        font-size: 5.5pt;
    }
    table.data-table thead {
        display: table-header-group;
    }
    table.data-table thead tr {
        background-color: #4c1d95;
    }
    table.data-table thead th {
        padding: 4px 6px;
        text-align: left;
        vertical-align: middle;
        font-weight: bold;
        font-size: 5pt;
        text-transform: uppercase;
        letter-spacing: 0.3pt;
        color: #ffffff;
    }
    table.data-table tbody tr {
        page-break-inside: avoid;
    }
    table.data-table tbody tr:nth-child(even) {
        background-color: #faf9fc;
    }
    table.data-table tbody tr:nth-child(odd) {
        background-color: #ffffff;
    }
    table.data-table tbody td {
        padding: 4px 6px;
        border-bottom: 1px solid #eceaf3;
        vertical-align: top;
        line-height: 1.25;
        color: #1f2937;
    }

    /* ── Texto secundario dentro de una celda ── */
    .cell-sub {
        color: #6b7280;
        font-size: 5pt;
    }

    /* ── Estados de fila (fondo claro, texto negro legible) ── */
    tr.row-signed td   { background-color: #d8f3e0 !important; color: #1f2937 !important; }
    tr.row-unsigned td { background-color: #fdfbd0 !important; color: #1f2937 !important; }
    tr.row-nopos td    { background-color: #ffffff !important; color: #1f2937 !important; }

    /* ── Badges ── */
    .badge {
        display: inline-block;
        padding: 1px 5px;
        border-radius: 8px;
        font-size: 5pt;
        font-weight: bold;
        letter-spacing: 0.2pt;
        color: #1f2937;
    }
    .badge-green  { background-color: #bbf7d0; }
    .badge-amber  { background-color: #fde68a; }
    .badge-red    { background-color: #fecaca; }
    .badge-blue   { background-color: #bfdbfe; }
    .badge-gray   { background-color: #e5e7eb; }
    .badge-purple { background-color: #ddd6fe; }

    /* ── Pie de página (no se reduce) ── */
    .pdf-footer {
        font-size: 7.5pt;
        color: #6b7280;
        text-align: right;
        border-top: 1px solid #e5e7eb;
        padding-top: 4px;
    }
</style>
