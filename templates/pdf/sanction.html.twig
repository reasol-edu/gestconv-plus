{% extends 'pdf/layout.html.twig' %}

{% block content %}
    <p class="section-title">{{ 'sanction.show_title'|trans({}, 'admin') }}</p>

    <table class="data-table">
        <tbody>
            <tr>
                <td><span class="cell-sub">{{ 'incident.col.student'|trans({}, 'admin') }}</span><br>{{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}</td>
                <td><span class="cell-sub">{{ 'incident.col.group'|trans({}, 'admin') }}</span><br>{{ sanction.group.name }}</td>
            </tr>
            <tr>
                <td><span class="cell-sub">{{ 'sanction.col.registered_by'|trans({}, 'admin') }}</span><br>{{ sanction.registeredBy.name.lastName }}, {{ sanction.registeredBy.name.firstName }}</td>
                <td><span class="cell-sub">{{ 'sanction.col.created_at'|trans({}, 'admin') }}</span><br>{{ sanction.createdAt|date('format.datetime'|trans) }}</td>
            </tr>
            <tr>
                <td colspan="2">
                    <span class="cell-sub">{{ 'incident.col.status'|trans({}, 'admin') }}</span><br>
                    <span class="badge {{ sanction.notified ? 'badge-green' : 'badge-amber' }}">
                        {{ (sanction.notified ? 'notification.badge.notified' : 'notification.badge.pending')|trans({}, 'notifications') }}
                    </span>
                </td>
            </tr>
        </tbody>
    </table>

    <p class="subsection-title">{{ 'sanction.section.measures'|trans({}, 'admin') }}</p>
    {% if sanction.noMeasureApplied %}
        <p><span class="badge badge-gray">{{ 'sanction.badge.no_measure'|trans({}, 'admin') }}</span></p>
        {% if sanction.noMeasureReason %}
            <p class="cell-sub">{{ 'sanction.field.no_measure_reason'|trans({}, 'admin') }}</p>
            <div class="prose-block">{{ sanction.noMeasureReason|sanitize_html('app.rich_text') }}</div>
        {% endif %}
    {% else %}
        <p>
            {% for measure in sanction.measures %}
                <span class="badge badge-blue">{{ measure.name }}</span>
            {% else %}
                <span class="cell-sub">&mdash;</span>
            {% endfor %}
        </p>
    {% endif %}

    {% if sanction.effectiveFrom and sanction.effectiveTo %}
        <p class="subsection-title">{{ 'sanction.field.effective_from'|trans({}, 'admin') }} — {{ 'sanction.field.effective_to'|trans({}, 'admin') }}</p>
        <p>{{ sanction.effectiveFrom|date('format.date'|trans) }} &rarr; {{ sanction.effectiveTo|date('format.date'|trans) }}</p>
    {% endif %}

    <p class="subsection-title">{{ 'sanction.field.details'|trans({}, 'admin') }}</p>
    <div class="prose-block">{{ sanction.details|sanitize_html('app.rich_text') }}</div>

    <p class="subsection-title">{{ 'sanction.section.followup'|trans({}, 'admin') }}</p>
    <table class="data-table">
        <tbody>
            <tr>
                <td colspan="2">
                    <span class="cell-sub">{{ 'sanction.field.registered_in_seneca'|trans({}, 'admin') }}</span><br>
                    {% if sanction.registeredInSeneca is same as true %}
                        <span class="badge badge-blue">Sí</span>
                    {% elseif sanction.registeredInSeneca is same as false %}
                        <span class="badge badge-gray">No</span>
                    {% else %}
                        &mdash;
                    {% endif %}
                </td>
            </tr>
            {% if not sanction.noMeasureApplied %}
                <tr>
                    <td>
                        <span class="cell-sub">{{ 'sanction.field.measures_effective'|trans({}, 'admin') }}</span><br>
                        {% if sanction.measuresEffective is same as true %}
                            <span class="badge badge-green">Sí</span>
                        {% elseif sanction.measuresEffective is same as false %}
                            <span class="badge badge-red">No</span>
                        {% else %}
                            &mdash;
                        {% endif %}
                    </td>
                    <td>
                        <span class="cell-sub">{{ 'sanction.field.family_claimed'|trans({}, 'admin') }}</span><br>
                        {% if sanction.familyClaimed is same as true %}
                            <span class="badge badge-amber">Sí</span>
                        {% elseif sanction.familyClaimed is same as false %}
                            <span class="badge badge-gray">No</span>
                        {% else %}
                            &mdash;
                        {% endif %}
                    </td>
                </tr>
                {% if sanction.familyClaimed is same as true and sanction.familyClaimAttitude %}
                    <tr>
                        <td colspan="2">
                            <span class="cell-sub">{{ 'sanction.field.family_claim_attitude'|trans({}, 'admin') }}</span><br>
                            <div class="prose-block">{{ sanction.familyClaimAttitude|sanitize_html('app.rich_text') }}</div>
                        </td>
                    </tr>
                {% endif %}
            {% endif %}
        </tbody>
    </table>

    <p class="subsection-title">{{ 'sanction.observation.title'|trans({}, 'admin') }}</p>
    {% if observations is empty %}
        <p class="cell-sub">{{ 'sanction.observation.empty'|trans({}, 'admin') }}</p>
    {% else %}
        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'ui.date'|trans }}</th>
                    <th>{{ 'sanction.col.registered_by'|trans({}, 'admin') }}</th>
                    <th>{{ 'sanction.observation.field.text'|trans({}, 'admin') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for observation in observations %}
                    <tr>
                        <td style="white-space: nowrap">{{ observation.registeredAt|date('format.datetime'|trans) }}</td>
                        <td style="white-space: nowrap">{{ observation.registeredBy.name.lastName }}, {{ observation.registeredBy.name.firstName }}</td>
                        <td>{{ observation.text|sanitize_html('app.rich_text') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <p class="subsection-title">{{ 'notification.history.title'|trans({}, 'notifications') }}</p>
    {% include 'pdf/_communication_history.html.twig' with { history: history } %}

    <p class="section-title">{{ 'sanction.section.reports'|trans({}, 'admin') }}</p>
    {% for report in sanction.reports %}
        {% include 'pdf/_incident_report_block.html.twig' with {
            report: report,
            reportObservations: observationsByReport[report.id.toRfc4122] ?? [],
            reportHistory: communicationsByReport[report.id.toRfc4122] ?? [],
        } %}
    {% endfor %}

    {% if footerHtml %}
        <div class="prose-block">{{ footerHtml|raw }}</div>
    {% endif %}
{% endblock %}
