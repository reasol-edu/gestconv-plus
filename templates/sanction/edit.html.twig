{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'sanction.edit_title'|trans({}, 'admin') }} · {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_sanctions_index') }}" class="hover:text-forest-600 transition-colors">{{ 'sanction.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'sanction.edit_title'|trans({}, 'admin') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'sanction.edit_title'|trans({}, 'admin') }}</h1>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 space-y-1">
            {% for error in errors %}
                <p class="text-sm text-red-700">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_sanctions_edit', {id: sanction.id}) }}" class="space-y-8"
          data-controller="form-submit sanction-measures sanction-date-range"
          data-sanction-date-range-non-working-dates-value="{{ nonWorkingDayDates|default([])|json_encode }}"
          data-sanction-date-range-blocked-message-value="{{ 'non_working_date.selection_blocked'|trans({}, 'admin') }}"
          data-action="submit->sanction-date-range#preventIfInvalid">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_sanction_' ~ sanction.id) }}">

        {# ── Estudiante (readonly) ──────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6">
            <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3 mb-4">
                {{ 'sanction.section.student'|trans({}, 'admin') }}
            </h2>
            <p class="text-sm text-gray-700 font-medium">
                {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
                <span class="ml-2 text-gray-400 font-normal">{{ sanction.group.name }}</span>
            </p>
        </div>

        {% if not canEditAll %}
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                {{ ux_icon('heroicons:information-circle', {class: 'inline h-4 w-4 mr-1 shrink-0'}) }}
                {{ 'sanction.notice.followup_only_edit'|trans({}, 'admin') }}
            </div>
        {% endif %}

        {% if canEditAll %}
        {# ── Partes asociados ───────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6 space-y-3"
             {% if errors.reports is defined %}aria-invalid="true" tabindex="-1"{% endif %}>
            <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">
                {{ 'sanction.section.reports'|trans({}, 'admin') }} <span class="text-red-500" aria-hidden="true">*</span>
            </h2>
            {% if errors.reports is defined %}
                <p class="text-xs text-red-600">{{ errors.reports }}</p>
            {% endif %}
            {% set linkedIds = sanction.reports|map(r => r.id.toRfc4122) %}
            {% if availableReports is empty %}
                <p class="text-sm text-gray-500">{{ 'sanction.no_eligible_reports'|trans({}, 'admin') }}</p>
            {% else %}
                <p class="text-xs text-gray-400 mb-2">{{ 'sanction.section.reports_help'|trans({}, 'admin') }}</p>
                {% for report in availableReports %}
                    <div class="flex items-start gap-3">
                        <input type="checkbox" name="reports[]" value="{{ report.id.toRfc4122 }}"
                               {{ report.id.toRfc4122 in linkedIds ? 'checked' : '' }}
                               class="mt-1 h-4 w-4 shrink-0 rounded border-gray-300 text-forest-600 focus:ring-forest-500">
                        <div class="flex-1 min-w-0">
                            <span class="text-sm text-gray-800 font-mono">#{{ report.number }}</span>
                            <span class="text-xs text-gray-500 ml-2">{{ report.occurredAt|date('format.datetime'|trans) }}</span>
                            <span class="text-xs text-gray-500 ml-2">{{ report.registeredBy.name.lastName }}, {{ report.registeredBy.name.firstName }}</span>
                            <div class="prose prose-sm max-w-none text-gray-700 mt-1">{{ report.description|sanitize_html('app.rich_text') }}</div>
                            {% set reportObservations = observationsByReport[report.id.toRfc4122] ?? [] %}
                            {% set reportCommunications = communicationsByReport[report.id.toRfc4122] ?? [] %}
                            <details class="mt-2">
                                <summary class="cursor-pointer text-xs font-semibold text-forest-700 hover:text-forest-900 select-none">
                                    {{ 'sanction.section.report_details_toggle'|trans({}, 'admin') }}
                                </summary>
                                <div class="mt-3">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">{{ 'incident.col.behaviors'|trans({}, 'admin') }}</p>
                                    {% include 'incident/_behavior_badges.html.twig' with { behaviors: report.behaviors } %}
                                </div>
                                {% if reportObservations is not empty %}
                                    <div class="mt-3">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">{{ 'incident.observation.title'|trans({}, 'admin') }}</p>
                                        {% include 'incident/_observation_list.html.twig' with { observations: reportObservations } %}
                                    </div>
                                {% endif %}
                                <div class="mt-3">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">{{ 'notification.history.title'|trans({}, 'notifications') }}</p>
                                    {% include 'notification/_communication_history.html.twig' with { history: reportCommunications } %}
                                </div>
                            </details>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>

        {# ── Medidas disciplinarias ─────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6 space-y-5"
             data-controller="checkbox-filter"
             data-checkbox-filter-singular-value="{{ 'checkbox_filter.selected_one'|trans({}, 'admin') }}"
             data-checkbox-filter-plural-value="{{ 'checkbox_filter.selected_many'|trans({}, 'admin') }}">

            <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">
                {{ 'sanction.section.measures'|trans({}, 'admin') }}
                <span data-checkbox-filter-target="count" class="ml-2 text-xs font-normal text-forest-700" aria-live="polite"></span>
            </h2>

            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">{{ 'sanction.field.measures_applied'|trans({}, 'admin') }}</span>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <twig:Form:RadioCard
                        name="no_measure_applied"
                        value="0"
                        label="{{ 'sanction.field.measures_applied_yes'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.measures_applied_yes_help'|trans({}, 'admin') }}"
                        :checked="not sanction.noMeasureApplied"
                        data-action="change->sanction-measures#toggle"
                    />
                    <twig:Form:RadioCard
                        name="no_measure_applied"
                        value="1"
                        label="{{ 'sanction.field.measures_applied_no'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.measures_applied_no_help'|trans({}, 'admin') }}"
                        :checked="sanction.noMeasureApplied"
                        data-sanction-measures-target="noMeasureRadio"
                        data-action="change->sanction-measures#toggle"
                    />
                </div>
            </div>

            {% set selectedMeasureIds = sanction.measures|map(m => m.id.toRfc4122) %}

            <div data-sanction-measures-target="measureSelector"
                 {% if errors.measures is defined %}aria-invalid="true" tabindex="-1"{% endif %}>
                {% if errors.measures is defined %}
                    <p class="mb-3 text-xs text-red-600">{{ errors.measures }}</p>
                {% endif %}

                <input type="search"
                       data-checkbox-filter-target="input"
                       data-action="input->checkbox-filter#filter"
                       placeholder="{{ 'checkbox_filter.placeholder'|trans({}, 'admin') }}"
                       aria-label="{{ 'checkbox_filter.placeholder'|trans({}, 'admin') }}"
                       class="mb-4 block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2 text-sm text-gray-900
                              focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">

                {% for group in measuresByCategory %}
                    <div data-checkbox-filter-target="group" class="{{ not loop.last ? 'mb-4' : '' }}">
                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">
                            {{ group.category.name }}
                        </p>
                        <div class="space-y-2">
                            {% for measure in group.measures %}
                                <label class="flex items-start gap-3 cursor-pointer group"
                                       data-sanction-measures-target="measureLabel"
                                       data-checkbox-filter-target="item">
                                    <input type="checkbox" name="measures[]" value="{{ measure.id.toRfc4122 }}"
                                           {{ measure.id.toRfc4122 in selectedMeasureIds ? 'checked' : '' }}
                                           data-sanction-measures-target="measureCheckbox"
                                           data-action="change->sanction-measures#updateDates change->checkbox-filter#updateCount"
                                           data-has-date-range="{{ measure.hasDateRange ? '1' : '0' }}"
                                           class="mt-0.5 h-4 w-4 rounded border-gray-300 text-forest-600 focus:ring-forest-500">
                                    <span class="text-sm text-gray-700 group-hover:text-gray-900">
                                        {{ measure.name }}
                                        {% if measure.hasDateRange %}
                                            <span class="ml-1 text-xs text-amber-600">({{ 'sanction.badge.has_date_range'|trans({}, 'admin') }})</span>
                                        {% endif %}
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
                <p data-checkbox-filter-target="empty" class="hidden text-xs text-gray-400">{{ 'checkbox_filter.no_matches'|trans({}, 'admin') }}</p>
            </div>

            <div data-sanction-measures-target="noMeasureReasonBlock"
                 class="{{ not sanction.noMeasureApplied ? 'hidden' : '' }} space-y-2">
                <twig:Form:RichEditor
                    id="no_measure_reason"
                    name="no_measure_reason"
                    label="{{ 'sanction.field.no_measure_reason'|trans({}, 'admin') }}"
                    value="{{ sanction.noMeasureReason ?? '' }}"
                    :error="errors.no_measure_reason ?? null"
                />
            </div>

            <div data-sanction-measures-target="dateBlock"
                 data-sanction-date-range-target="dateBlock"
                 class="{{ not sanction.effectiveFrom ? 'hidden' : '' }} grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] gap-4 items-start pt-2 border-t border-gray-100">
                <div>
                    <label for="effective_from" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'sanction.field.effective_from'|trans({}, 'admin') }}
                    </label>
                    <input type="date" id="effective_from" name="effective_from"
                           value="{{ sanction.effectiveFrom ? sanction.effectiveFrom|date('Y-m-d') : '' }}"
                           {% if errors.effective_from is defined %}aria-invalid="true"{% endif %}
                           data-sanction-measures-target="effectiveFrom"
                           data-sanction-date-range-target="start"
                           data-action="change->sanction-date-range#startChanged"
                           class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                                  focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                    {% if errors.effective_from is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.effective_from }}</p>
                    {% endif %}
                    <p data-sanction-date-range-target="startWarning" class="mt-1 text-xs text-red-600 hidden"></p>
                </div>
                <div class="flex flex-col items-center gap-1.5 pt-0 sm:pt-6">
                    <span class="text-xs font-medium text-gray-500">{{ 'sanction.field.school_days'|trans({}, 'admin') }}</span>
                    <div class="flex items-center gap-2 rounded-xl border border-gray-200 bg-gray-50 px-2 py-1.5">
                        <button type="button" data-action="sanction-date-range#decrement"
                                class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-gray-500 hover:bg-white hover:text-forest-600 transition-colors">
                            {{ ux_icon('heroicons:minus', {class: 'h-3.5 w-3.5'}) }}
                        </button>
                        <input type="number" min="1" max="90" inputmode="numeric"
                               data-sanction-date-range-target="count"
                               data-action="change->sanction-date-range#countChanged"
                               class="w-12 border-0 bg-transparent text-center text-sm font-semibold text-gray-900 focus:outline-none focus:ring-0 [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none">
                        <button type="button" data-action="sanction-date-range#increment"
                                class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-gray-500 hover:bg-white hover:text-forest-600 transition-colors">
                            {{ ux_icon('heroicons:plus', {class: 'h-3.5 w-3.5'}) }}
                        </button>
                    </div>
                    <p class="text-[11px] text-gray-400 text-center max-w-[8rem]">{{ 'sanction.field.school_days_help'|trans({}, 'admin') }}</p>
                </div>
                <div>
                    <label for="effective_to" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'sanction.field.effective_to'|trans({}, 'admin') }}
                    </label>
                    <input type="date" id="effective_to" name="effective_to"
                           value="{{ sanction.effectiveTo ? sanction.effectiveTo|date('Y-m-d') : '' }}"
                           {% if errors.effective_to is defined %}aria-invalid="true"{% endif %}
                           data-sanction-measures-target="effectiveTo"
                           data-sanction-date-range-target="end"
                           data-action="change->sanction-date-range#endChanged"
                           class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                                  focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                    {% if errors.effective_to is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.effective_to }}</p>
                    {% endif %}
                    <p data-sanction-date-range-target="endWarning" class="mt-1 text-xs text-red-600 hidden"></p>
                </div>
            </div>
        </div>

        {# ── Detalle de la sanción ──────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6 space-y-4">
            <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">
                {{ 'sanction.section.details'|trans({}, 'admin') }}
            </h2>
            <twig:Form:RichEditor
                id="details"
                name="details"
                label="{{ 'sanction.field.details'|trans({}, 'admin') }}"
                value="{{ sanction.details }}"
                :required="true"
                :error="errors.details ?? null"
            />
            <div>
                <label for="calendar_label" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'sanction.field.calendar_label'|trans({}, 'admin') }}
                </label>
                <input type="text" id="calendar_label" name="calendar_label"
                       value="{{ sanction.calendarLabel ?? '' }}"
                       maxlength="255"
                       placeholder="{{ 'sanction.field.calendar_label_placeholder'|trans({}, 'admin') }}"
                       class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                              focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                <p class="mt-1 text-xs text-gray-400">{{ 'sanction.field.calendar_label_help'|trans({}, 'admin') }}</p>
            </div>
        </div>
        {% endif %}{# /canEditAll #}

        {# ── Seguimiento ────────────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6 space-y-6"
             {% if not canEditAll and sanction.noMeasureApplied %}style="display:none"{% endif %}
             data-sanction-measures-target="followupBlock">
            <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">
                {{ 'sanction.section.followup'|trans({}, 'admin') }}
            </h2>

            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">{{ 'sanction.field.registered_in_seneca'|trans({}, 'admin') }}</span>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <twig:Form:RadioCard
                        name="registered_in_seneca"
                        value="0"
                        label="{{ 'sanction.field.registered_in_seneca_no'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.registered_in_seneca_no_help'|trans({}, 'admin') }}"
                        :checked="sanction.registeredInSeneca is same as false"
                    />
                    <twig:Form:RadioCard
                        name="registered_in_seneca"
                        value="1"
                        label="{{ 'sanction.field.registered_in_seneca_yes'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.registered_in_seneca_yes_help'|trans({}, 'admin') }}"
                        :checked="sanction.registeredInSeneca is same as true"
                    />
                </div>
            </div>

            {% if canEditAll or not sanction.noMeasureApplied %}
            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">{{ 'sanction.field.measures_effective'|trans({}, 'admin') }}</span>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <twig:Form:RadioCard
                        name="measures_effective"
                        value="0"
                        label="{{ 'sanction.field.measures_effective_no'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.measures_effective_no_help'|trans({}, 'admin') }}"
                        :checked="sanction.measuresEffective is same as false"
                    />
                    <twig:Form:RadioCard
                        name="measures_effective"
                        value="1"
                        label="{{ 'sanction.field.measures_effective_yes'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.measures_effective_yes_help'|trans({}, 'admin') }}"
                        :checked="sanction.measuresEffective is same as true"
                    />
                </div>
            </div>

            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">{{ 'sanction.field.family_claimed'|trans({}, 'admin') }}</span>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <twig:Form:RadioCard
                        name="family_claimed"
                        value="0"
                        label="{{ 'sanction.field.family_claimed_no'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.family_claimed_no_help'|trans({}, 'admin') }}"
                        :checked="sanction.familyClaimed is same as false"
                        data-sanction-measures-target="familyClaimedRadio"
                        data-action="change->sanction-measures#updateFollowup"
                    />
                    <twig:Form:RadioCard
                        name="family_claimed"
                        value="1"
                        label="{{ 'sanction.field.family_claimed_yes'|trans({}, 'admin') }}"
                        help="{{ 'sanction.field.family_claimed_yes_help'|trans({}, 'admin') }}"
                        :checked="sanction.familyClaimed is same as true"
                        data-sanction-measures-target="familyClaimedRadio"
                        data-action="change->sanction-measures#updateFollowup"
                    />
                </div>
            </div>

            <div data-sanction-measures-target="familyClaimAttitudeBlock"
                 class="{{ sanction.familyClaimed is not same as true ? 'hidden' : '' }}">
                <twig:Form:RichEditor
                    id="family_claim_attitude"
                    name="family_claim_attitude"
                    label="{{ 'sanction.field.family_claim_attitude'|trans({}, 'admin') }}"
                    value="{{ sanction.familyClaimAttitude ?? '' }}"
                    :required="true"
                    :error="errors.family_claim_attitude ?? null"
                />
            </div>
            {% endif %}
        </div>

        {# ── Botones ────────────────────────────────────────────────────── #}
        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                      hover:bg-gray-50 transition-colors">
                {{ 'sanction.cancel'|trans({}, 'admin') }}
            </a>
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-forest-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                {{ 'sanction.save'|trans({}, 'admin') }}
            </button>
        </div>
    </form>
</div>
{% endblock %}
