{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'sanction.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'sanction.title'|trans({}, 'admin') }}</h1>
            <p class="mt-1 text-sm text-gray-500">{{ centre.name }}</p>
        </div>
        {% if (is_granted('ROLE_ADMIN') or is_granted('educational_centre.section', centre)) and not is_viewing_past_year() %}
            <a href="{{ path('app_sanctions_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                      hover:bg-forest-700 transition-colors shadow-xs shrink-0">
                {{ ux_icon('heroicons:plus', {class: 'h-4 w-4'}) }}
                {{ 'sanction.new'|trans({}, 'admin') }}
            </a>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:SanctionListComponent :centre="centre" :pendingTasksOnly="pendingTasksOnly" />
    </div>

</div>
{% endblock %}
