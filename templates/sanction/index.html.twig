{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'sanction.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-5xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'sanction.title'|trans({}, 'admin') }}</h1>
            <p class="mt-1 text-sm text-gray-500">{{ centre.name }}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') or is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_sanctions_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                      hover:bg-forest-700 transition-colors shadow-xs shrink-0">
                {{ ux_icon('heroicons:plus', {class: 'h-4 w-4'}) }}
                {{ 'sanction.new'|trans({}, 'admin') }}
            </a>
        {% endif %}
    </div>

    {% if sanctions is empty %}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs px-6 py-16 text-center">
            {{ ux_icon('heroicons:scale', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm text-gray-500">{{ 'sanction.empty'|trans({}, 'admin') }}</p>
        </div>
    {% else %}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.student'|trans({}, 'admin') }}</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.group'|trans({}, 'admin') }}</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.measures'|trans({}, 'admin') }}</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.effective_period'|trans({}, 'admin') }}</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.created_at'|trans({}, 'admin') }}</th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for sanction in sanctions %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 font-medium text-gray-900">
                                    {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
                                </td>
                                <td class="px-6 py-4 text-gray-600">{{ sanction.group.name }}</td>
                                <td class="px-6 py-4">
                                    {% if sanction.noMeasureApplied %}
                                        <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-500 px-2.5 py-0.5 text-xs font-medium">
                                            {{ 'sanction.badge.no_measure'|trans({}, 'admin') }}
                                        </span>
                                    {% else %}
                                        <div class="flex flex-wrap gap-1">
                                            {% for measure in sanction.measures %}
                                                <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-700 px-2.5 py-0.5 text-xs font-medium">
                                                    {{ measure.name }}
                                                </span>
                                            {% else %}
                                                <span class="text-xs text-gray-400">—</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-gray-600 text-xs">
                                    {% if sanction.effectiveFrom and sanction.effectiveTo %}
                                        {{ sanction.effectiveFrom|date('d/m/Y') }} – {{ sanction.effectiveTo|date('d/m/Y') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-gray-500 text-xs">
                                    {{ sanction.createdAt|date('d/m/Y') }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
                                       class="inline-flex items-center gap-1 rounded-lg border border-gray-200 px-2.5 py-1.5 text-xs font-medium text-gray-700
                                              hover:bg-gray-50 transition-colors">
                                        {{ ux_icon('heroicons:eye', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'sanction.view'|trans({}, 'admin') }}
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
