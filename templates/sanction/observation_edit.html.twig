{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'sanction.observation.edit'|trans({}, 'admin') }} · {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_sanctions_index') }}" class="hover:text-forest-600 transition-colors">{{ 'sanction.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'sanction.observation.edit'|trans({}, 'admin') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'sanction.observation.edit'|trans({}, 'admin') }}</h1>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6">
        <form method="post"
              action="{{ path('app_sanctions_edit_observation', {id: sanction.id, observationId: observation.id}) }}"
              class="space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_sanction_observation_' ~ observation.id) }}">

            {% if canEditDate %}
                <div>
                    <label for="registered_at" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'ui.date'|trans }}
                    </label>
                    <input type="datetime-local" id="registered_at" name="registered_at"
                           value="{{ observation.registeredAt|date('Y-m-d\\TH:i') }}"
                           {% if errors.registered_at is defined %}aria-invalid="true"{% endif %}
                           class="block rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                                  focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                    {% if errors.registered_at is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.registered_at }}</p>
                    {% endif %}
                </div>
            {% endif %}

            <div>
                <twig:Form:RichEditor
                    id="observation_text"
                    name="text"
                    label="{{ 'sanction.observation.field.text'|trans({}, 'admin') }}"
                    value="{{ observation.text }}"
                    :required="true"
                    :error="errors.text ?? null"
                />
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
                   class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'ui.cancel'|trans }}
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-forest-700 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                    {{ 'ui.save'|trans }}
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
