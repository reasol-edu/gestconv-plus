{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'sanction.new'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
{% set totalPages = total > 0 ? max(1, (total / perPage)|round(0, 'ceil')) : 1 %}
{% set fromItem   = total == 0 ? 0 : (page - 1) * perPage + 1 %}
{% set toItem     = min(page * perPage, total) %}

<div class="px-6 py-8 max-w-5xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_sanctions_index') }}" class="hover:text-forest-600 transition-colors">{{ 'sanction.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'sanction.new'|trans({}, 'admin') }}</h1>
    </div>

    {# ── Filtro ──────────────────────────────────────────────────────────────── #}
    <form method="get" action="{{ path('app_sanctions_new') }}" class="flex items-center gap-3">
        <div class="relative flex-1 max-w-sm">
            <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-400">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4'}) }}
            </span>
            <input type="search"
                   name="search"
                   value="{{ search }}"
                   placeholder="{{ 'sanction.filter.search_placeholder'|trans({}, 'admin') }}"
                   autocomplete="off"
                   class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-2 pl-9 pr-3.5 text-sm text-gray-900
                          focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
        </div>
        <button type="submit"
                class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700
                       hover:bg-gray-50 transition-colors">
            {{ 'sanction.filter.apply'|trans({}, 'admin') }}
        </button>
        {% if search != '' %}
            <a href="{{ path('app_sanctions_new') }}"
               class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
                {{ 'sanction.filter.clear'|trans({}, 'admin') }}
            </a>
        {% endif %}
    </form>

    {# ── Tabla ───────────────────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-100 text-sm">
                <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-500">
                    <tr>
                        <th class="px-6 py-3 text-left">{{ 'sanction.col.student'|trans({}, 'admin') }}</th>
                        <th class="px-4 py-3 text-left">{{ 'sanction.col.group'|trans({}, 'admin') }}</th>
                        <th class="px-4 py-3 text-center">{{ 'sanction.col.sanctionable'|trans({}, 'admin') }}</th>
                        <th class="px-4 py-3 text-center">{{ 'sanction.col.serious_abbr'|trans({}, 'admin') }}</th>
                        <th class="px-4 py-3 text-center">{{ 'sanction.col.prescribed'|trans({}, 'admin') }}</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    {% for row in rows %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-3 font-medium text-gray-900 whitespace-nowrap">
                                {{ row.lastName }}, {{ row.firstName }}
                            </td>
                            <td class="px-4 py-3 text-gray-600 whitespace-nowrap">
                                {{ row.groupName }}
                            </td>
                            <td class="px-4 py-3 text-center">
                                {% if row.sanctionableCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">
                                        {{ row.sanctionableCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-center">
                                {% if row.seriousCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-700">
                                        {{ row.seriousCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-center">
                                {% if row.prescribedCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500">
                                        {{ row.prescribedCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a href="{{ path('app_sanctions_new', {studentId: row.studentId, groupId: row.groupId}) }}"
                                   class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                          hover:bg-forest-700 transition-colors shadow-xs">
                                    {{ ux_icon('heroicons:plus', {class: 'h-3.5 w-3.5'}) }}
                                    {{ 'sanction.new'|trans({}, 'admin') }}
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">
                                {% if search != '' %}
                                    {{ 'sanction.empty_search'|trans({}, 'admin') }}
                                {% else %}
                                    {{ 'sanction.empty_students'|trans({}, 'admin') }}
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# ── Paginación ──────────────────────────────────────────────────────── #}
        {% if totalPages > 1 %}
        <div class="flex items-center justify-between border-t border-gray-100 px-6 py-3 gap-4 flex-wrap">
            <p class="text-xs text-gray-500 shrink-0">
                {{ 'pagination.summary'|trans({'%from%': fromItem, '%to%': toItem, '%total%': total}) }}
            </p>
            <nav class="flex items-center gap-1" aria-label="{{ 'pagination.nav_label'|trans }}">
                {# Anterior #}
                {% if page > 1 %}
                    <a href="{{ path('app_sanctions_new', {search: search, page: page - 1}) }}"
                       class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500
                              hover:bg-gray-50 hover:border-gray-300 transition-colors"
                       aria-label="{{ 'pagination.previous'|trans }}">
                        {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                    </a>
                {% else %}
                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                        {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                    </span>
                {% endif %}

                {# Números #}
                {% set delta = 2 %}
                {% set pages = [1] %}
                {% for p in range(max(2, page - delta), min(totalPages - 1, page + delta)) %}
                    {% set pages = pages|merge([p]) %}
                {% endfor %}
                {% set pages = pages|merge([totalPages]) %}

                {% for p in pages %}
                    {% if loop.index > 1 and pages[loop.index0 - 1] is defined and p - pages[loop.index0 - 1] > 1 %}
                        <span class="inline-flex items-center justify-center h-8 px-1 text-xs text-gray-400 select-none">…</span>
                    {% endif %}
                    {% if p == page %}
                        <span class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg
                                     bg-forest-600 text-white text-xs font-semibold"
                              aria-current="page">{{ p }}</span>
                    {% else %}
                        <a href="{{ path('app_sanctions_new', {search: search, page: p}) }}"
                           class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg border border-gray-200
                                  text-gray-600 text-xs hover:bg-gray-50 hover:border-gray-300 transition-colors">{{ p }}</a>
                    {% endif %}
                {% endfor %}

                {# Siguiente #}
                {% if page < totalPages %}
                    <a href="{{ path('app_sanctions_new', {search: search, page: page + 1}) }}"
                       class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500
                              hover:bg-gray-50 hover:border-gray-300 transition-colors"
                       aria-label="{{ 'pagination.next'|trans }}">
                        {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                    </a>
                {% else %}
                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                        {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                    </span>
                {% endif %}
            </nav>
        </div>
        {% endif %}

    </div>

    <div class="flex justify-start">
        <a href="{{ path('app_sanctions_index') }}"
           class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                  hover:bg-gray-50 transition-colors">
            {{ 'sanction.cancel'|trans({}, 'admin') }}
        </a>
    </div>

</div>
{% endblock %}
