{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'non_working_day.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto">

    <div class="mb-6 flex items-start justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                {% include 'components/_breadcrumb_home.html.twig' %}
                <a href="{{ path('app_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">
                    {{ 'educational_centre'|trans({}, 'navigation') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'non_working_day.title'|trans({}, 'admin') }}</h1>
            <p class="mt-1 text-sm text-gray-500">{{ year.name }}</p>
        </div>
        <a href="{{ path('app_centre_non_working_days_import', {centreId: centre.id}) }}"
           class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold
                  text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors shadow-xs shrink-0">
            {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
            {{ 'non_working_day.import.button'|trans({}, 'admin') }}
        </a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">

        {# Lista de días no lectivos #}
        {% if days is empty %}
            <div class="px-6 py-8 text-center">
                <p class="text-sm text-gray-400">{{ 'non_working_day.empty'|trans({}, 'admin') }}</p>
            </div>
        {% else %}
            <ul class="divide-y divide-gray-100">
                {% for day in days %}
                    <li class="flex items-center gap-4 px-6 py-4">
                        <div class="flex-1 min-w-0 flex items-center gap-3">
                            <span class="text-sm font-medium text-gray-900 shrink-0">{{ day.date|date('format.date'|trans) }}</span>
                            {% if day.description %}
                                <span class="text-sm text-gray-500 truncate">{{ day.description }}</span>
                            {% endif %}
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            {# Editar #}
                            <a href="{{ path('app_centre_non_working_days_edit', {centreId: centre.id, dayId: day.id}) }}"
                               class="inline-flex items-center gap-1 rounded-lg border border-gray-200 px-2.5 py-1.5
                                      text-xs font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                                {{ 'non_working_day.action.edit'|trans({}, 'admin') }}
                            </a>
                            {# Eliminar #}
                            <form method="post"
                                  action="{{ path('app_centre_non_working_days_delete', {centreId: centre.id, dayId: day.id}) }}"
                                  class="js-confirm-form"
                                  data-confirm="{{ 'non_working_day.delete_confirm'|trans({}, 'admin')|e('html_attr') }}">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_non_working_day_' ~ day.id) }}">
                                <button type="submit"
                                        class="js-confirm-trigger inline-flex items-center gap-1 rounded-lg border border-red-200 px-2.5 py-1.5
                                               text-xs font-medium text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors">
                                    {{ ux_icon('heroicons:trash', {class: 'h-3.5 w-3.5'}) }}
                                    {{ 'non_working_day.action.delete'|trans({}, 'admin') }}
                                </button>
                            </form>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}

        {# Añadir día no lectivo #}
        <div class="border-t border-gray-100 px-6 py-5 bg-gray-50">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
                {{ 'non_working_day.add.title'|trans({}, 'admin') }}
            </p>
            <form method="post"
                  action="{{ path('app_centre_non_working_days_add', {centreId: centre.id}) }}"
                  class="flex flex-wrap gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token('add_non_working_day_' ~ centre.id) }}">
                <input type="date" name="date"
                       class="rounded-xl border border-gray-200 bg-white py-2.5 px-3.5 text-sm
                              focus:border-forest-500 focus:ring-3 focus:ring-forest-500/20 focus:outline-none transition-colors"
                       required>
                <input type="text" name="description"
                       placeholder="{{ 'non_working_day.field.description_placeholder'|trans({}, 'admin') }}"
                       class="flex-1 min-w-[12rem] rounded-xl border border-gray-200 bg-white py-2.5 px-3.5 text-sm
                              focus:border-forest-500 focus:ring-3 focus:ring-forest-500/20 focus:outline-none transition-colors">
                <button type="submit"
                        class="rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-forest-700 transition-colors shadow-xs shrink-0">
                    {{ ux_icon('heroicons:plus', {class: 'h-4 w-4 mr-1 inline'}) }}{{ 'non_working_day.add.submit'|trans({}, 'admin') }}
                </button>
            </form>
        </div>
    </div>

</div>
{% endblock %}
