{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'centre_teachers.subjects.title'|trans({}, 'admin') }} · {{ teacher.name.lastName }}, {{ teacher.name.firstName }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-5xl mx-auto space-y-4">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ 'educational_centre'|trans({}, 'navigation') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_centre_teachers_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ 'centre_teachers.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ teacher.username }}</p>
    </div>

    <twig:Admin:TeacherSubjectsComponent :centre="centre" :teacher="teacher" />

    <div class="text-right">
        <a href="{{ path('app_admin_teachers_edit', {id: teacher.id}) }}"
           class="text-sm text-forest-600 hover:text-forest-700 hover:underline transition-colors">
            {{ 'centre_teachers.subjects.link_global_edit'|trans({}, 'admin') }}
        </a>
    </div>

</div>
{% endblock %}
