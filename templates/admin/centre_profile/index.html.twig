{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'centre_profiles.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'centre_profiles.title'|trans({}, 'admin') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'centre_profiles.help'|trans({}, 'admin') }}</p>
    </div>

    {% if centre.activeAcademicYear is null %}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs px-6 py-4">
            <p class="text-sm text-gray-500">{{ 'centre_profiles.no_active_year'|trans({}, 'admin') }}</p>
        </div>
    {% else %}
        <form method="post" class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_centre_profiles_' ~ centre.id) }}">

            <div class="px-6 py-5 border-b border-gray-100">
                <label class="block text-sm font-medium text-gray-700 mb-0.5">
                    {{ 'centre_profiles.committee.label'|trans({}, 'admin') }}
                </label>
                <p class="text-xs text-gray-400 mb-2">{{ 'centre_profiles.committee.help'|trans({}, 'admin') }}</p>
                <select name="committee_members[]" multiple
                        data-controller="symfony--ux-autocomplete--autocomplete"
                        data-symfony--ux-autocomplete--autocomplete-url-value="{{ path('ux_entity_autocomplete', {alias: 'teacher_centre', academicYearId: centre.activeAcademicYear.id}) }}"
                        data-symfony--ux-autocomplete--autocomplete-min-characters-value="2"
                        data-symfony--ux-autocomplete--autocomplete-no-results-found-text-value="{{ 'autocomplete.no_results'|trans({}, 'admin') }}"
                        data-symfony--ux-autocomplete--autocomplete-tom-select-options-value='{"dropdownParent":"body"}'
                        class="w-full">
                    {% for teacher in selectedCommitteeMembers %}
                        <option value="{{ teacher.id }}" selected>{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="px-6 py-5 border-b border-gray-100">
                <label class="block text-sm font-medium text-gray-700 mb-0.5">
                    {{ 'centre_profiles.counselors.label'|trans({}, 'admin') }}
                </label>
                <p class="text-xs text-gray-400 mb-2">{{ 'centre_profiles.counselors.help'|trans({}, 'admin') }}</p>
                <select name="counselors[]" multiple
                        data-controller="symfony--ux-autocomplete--autocomplete"
                        data-symfony--ux-autocomplete--autocomplete-url-value="{{ path('ux_entity_autocomplete', {alias: 'teacher_centre', academicYearId: centre.activeAcademicYear.id}) }}"
                        data-symfony--ux-autocomplete--autocomplete-min-characters-value="2"
                        data-symfony--ux-autocomplete--autocomplete-no-results-found-text-value="{{ 'autocomplete.no_results'|trans({}, 'admin') }}"
                        data-symfony--ux-autocomplete--autocomplete-tom-select-options-value='{"dropdownParent":"body"}'
                        class="w-full">
                    {% for teacher in selectedCounselors %}
                        <option value="{{ teacher.id }}" selected>{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="px-6 py-4 bg-gray-50 flex justify-end">
                <button type="submit"
                        class="rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-forest-700 transition-colors shadow-xs">
                    {{ 'centre_profiles.save'|trans({}, 'admin') }}
                </button>
            </div>
        </form>
    {% endif %}

</div>
{% endblock %}
