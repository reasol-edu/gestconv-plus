{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'email_notification_log.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_educational_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'email_notification_log.title'|trans({}, 'admin') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'email_notification_log.help'|trans({}, 'admin') }}</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:EmailNotificationLogListComponent :centre="centre" />
    </div>

</div>
{% endblock %}
