{% extends 'layouts/app.html.twig' %}

{% block title %}Registro de actividad · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_admin') }}" class="hover:text-forest-600 transition-colors">Administración</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Registro de actividad</h1>
        <p class="mt-1 text-sm text-gray-500">Auditoría de acciones realizadas por los usuarios de la plataforma.</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:ActivityLogListComponent />
    </div>

</div>
{% endblock %}
