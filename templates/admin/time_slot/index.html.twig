{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'time_slot.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
                {% include 'components/_breadcrumb_home.html.twig' %}
                <a href="{{ path('app_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'time_slot.title'|trans({}, 'admin') }}</h1>
            {% set vy = view_year() %}
            {% if vy %}
                <p class="mt-1 text-sm {{ is_viewing_past_year() ? 'text-amber-600 font-medium' : 'text-gray-500' }}">{{ vy.name }}</p>
            {% endif %}
        </div>
        <div class="flex items-center gap-2 shrink-0">
            <a href="{{ path('app_centre_time_slots_import', {centreId: centre.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700
                      hover:bg-gray-50 hover:border-gray-300 transition-colors shadow-xs">
                {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
                {{ 'time_slot.import.button'|trans({}, 'admin') }}
            </a>
            <a href="{{ path('app_centre_time_slots_export', {centreId: centre.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700
                      hover:bg-gray-50 hover:border-gray-300 transition-colors shadow-xs">
                {{ ux_icon('heroicons:arrow-down-tray', {class: 'h-4 w-4'}) }}
                {{ 'time_slot.export.button'|trans({}, 'admin') }}
            </a>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:TimeSlotComponent :centre="centre" />
    </div>

</div>
{% endblock %}
