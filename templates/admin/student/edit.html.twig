{% extends 'layouts/app.html.twig' %}

{% block title %}{{ student.name.lastName }}, {{ student.name.firstName }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_centre_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_centre_students_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'students.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ student.name.lastName }}, {{ student.name.firstName }}</h1>
        <p class="mt-1 text-sm font-mono text-gray-500">{{ student.studentId }}</p>
    </div>

    <form method="post" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_student_' ~ student.id) }}">

        {# ── Datos del estudiante ─────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
            <div class="px-6 py-4 border-b border-gray-100 rounded-t-2xl">
                <h2 class="text-base font-semibold text-gray-900">{{ 'student.edit.title'|trans({}, 'admin') }}</h2>
            </div>
            <div class="px-6 py-6 space-y-5">
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
                    <twig:Form:Field
                        id="firstName" name="firstName" type="text"
                        label="{{ 'student.field.first_name'|trans({}, 'admin') }}"
                        value="{{ values.firstName }}"
                        :error="errors.firstName ?? null"
                        required="true" />

                    <div class="sm:col-span-2">
                        <twig:Form:Field
                            id="lastName" name="lastName" type="text"
                            label="{{ 'student.field.last_name'|trans({}, 'admin') }}"
                            value="{{ values.lastName }}"
                            :error="errors.lastName ?? null"
                            required="true" />
                    </div>
                </div>

                <twig:Form:Field
                    id="studentId" name="studentId" type="text"
                    label="{{ 'student.field.student_id'|trans({}, 'admin') }}"
                    value="{{ values.studentId }}"
                    :error="errors.studentId ?? null"
                    required="true" />

                {% if availableGroups is not empty %}
                    <div>
                        <label for="groups" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'student.field.groups'|trans({}, 'admin') }}
                        </label>
                        <select id="groups" name="groups[]" multiple
                                class="w-full text-sm ts-local"
                                data-placeholder="{{ 'student.field.groups_placeholder'|trans({}, 'admin')|e('html_attr') }}"
                                data-no-results="{{ 'student.field.groups_no_results'|trans({}, 'admin')|e('html_attr') }}">
                            {% for group in availableGroups %}
                                <option value="{{ group.id.toRfc4122 }}"
                                        data-programme="{{ group.programmeYear.programme.name|e('html_attr') }}"
                                        data-level="{{ group.programmeYear.name|e('html_attr') }}"
                                        {{ group.id.toRfc4122 in selectedGroupIds ? 'selected' : '' }}>
                                    {{ group.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── Tutores ──────────────────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ 'student.section.tutors'|trans({}, 'admin') }}</h2>
            </div>
            <div class="px-6 py-6 space-y-5">
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                    <twig:Form:Field
                        id="tutorName1" name="tutorName1" type="text"
                        label="{{ 'student.field.tutor_name_1'|trans({}, 'admin') }}"
                        value="{{ values.tutorName1 }}" />
                    <twig:Form:Field
                        id="tutorEmail1" name="tutorEmail1" type="email"
                        label="{{ 'student.field.tutor_email_1'|trans({}, 'admin') }}"
                        value="{{ values.tutorEmail1 }}" />
                </div>

                <div class="grid grid-cols-1 gap-5 pt-5 border-t border-gray-100 sm:grid-cols-2">
                    <twig:Form:Field
                        id="tutorName2" name="tutorName2" type="text"
                        label="{{ 'student.field.tutor_name_2'|trans({}, 'admin') }}"
                        value="{{ values.tutorName2 }}" />
                    <twig:Form:Field
                        id="tutorEmail2" name="tutorEmail2" type="email"
                        label="{{ 'student.field.tutor_email_2'|trans({}, 'admin') }}"
                        value="{{ values.tutorEmail2 }}" />
                </div>
            </div>
        </div>

        {# ── Teléfonos de contacto ────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ 'student.section.contact_phones'|trans({}, 'admin') }}</h2>
            </div>
            <div class="px-6 py-6 space-y-6">
                {% for i in 1..3 %}
                    <div class="space-y-3 {% if i > 1 %}pt-5 border-t border-gray-100{% endif %}">
                        <twig:Form:Field
                            id="contactPhone{{ i }}" name="contactPhone{{ i }}" type="tel"
                            label="{{ ('student.field.contact_phone_' ~ i)|trans({}, 'admin') }}"
                            value="{{ attribute(values, 'contactPhone' ~ i) }}" />
                        <twig:Form:RichEditor
                            id="contactPhone{{ i }}Notes" name="contactPhone{{ i }}Notes"
                            label="{{ ('student.field.contact_phone_' ~ i ~ '_notes')|trans({}, 'admin') }}"
                            value="{{ attribute(values, 'contactPhone' ~ i ~ 'Notes') }}" />
                    </div>
                {% endfor %}
            </div>
        </div>

        {# ── Observaciones ────────────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ 'student.section.notes'|trans({}, 'admin') }}</h2>
            </div>
            <div class="px-6 py-6">
                <twig:Form:RichEditor
                    id="details" name="details"
                    label="{{ 'student.field.details'|trans({}, 'admin') }}"
                    value="{{ values.details }}" />
            </div>
        </div>

        <div class="flex items-center justify-between">
            <a href="{{ path('app_centre_students_index', {centreId: centre.id}) }}"
               class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
                {{ 'student.cancel'|trans({}, 'admin') }}
            </a>
            <button type="submit"
                    class="rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-forest-700 transition-colors shadow-xs">
                {{ 'student.save'|trans({}, 'admin') }}
            </button>
        </div>
    </form>

    {# ── Zona peligrosa ───────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-red-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-red-100 bg-red-50">
            <h2 class="text-base font-semibold text-red-700">{{ 'student.delete_section'|trans({}, 'admin') }}</h2>
        </div>
        <div class="px-6 py-5 flex items-center justify-between gap-4">
            <p class="text-sm text-gray-600">{{ 'student.delete_warning'|trans({}, 'admin') }}</p>
            <form method="post"
                  action="{{ path('app_centre_students_delete', {centreId: centre.id, id: student.id}) }}"
                  class="js-confirm-form"
                  data-confirm="{{ 'students.delete_confirm'|trans({}, 'admin')|e('html_attr') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_student_' ~ student.id) }}">
                <button type="submit"
                        class="js-confirm-trigger inline-flex items-center gap-2 rounded-xl border border-red-300 px-4 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 hover:border-red-400 transition-colors shrink-0">
                    {{ ux_icon('heroicons:trash', {class: 'h-4 w-4'}) }}
                    {{ 'students.action.delete'|trans({}, 'admin') }}
                </button>
            </form>
        </div>
    </div>

</div>

{% if availableGroups is not empty %}
<script type="module">
import TomSelect from 'tom-select';

const el = document.getElementById('groups');
if (el) {

const placeholder = el.dataset.placeholder ?? '';
const noResults   = el.dataset.noResults   ?? '';

const options = [];
el.querySelectorAll('option').forEach(opt => {
    options.push({
        value:     opt.value,
        name:      opt.textContent.trim(),
        programme: opt.dataset.programme ?? '',
        level:     opt.dataset.level     ?? '',
        search:    `${opt.dataset.programme} ${opt.dataset.level} ${opt.textContent.trim()}`,
    });
});

const selected = Array.from(el.selectedOptions).map(o => o.value);

const ts = new TomSelect(el, {
    options,
    items:          selected,
    valueField:     'value',
    labelField:     'name',
    searchField:    ['search'],
    create:         false,
    maxOptions:     null,
    placeholder,

    plugins:        ['remove_button', 'checkbox_options'],
    render: {
        option: (d, esc) =>
            `<div class="ts-sg-option">
                <span class="ts-sg-name">${esc(d.name)}</span>
                <span class="ts-sg-teaching">${esc(d.programme)}</span>
            </div>`,
        item: (d, esc) =>
            `<span>${esc(d.name)}</span>`,
        no_results: () =>
            `<div class="no-results px-3 py-2 text-sm">${noResults}</div>`,
    },
});

const styleItems = () => ts.control.querySelectorAll('.item').forEach(item => {
    item.style.setProperty('background-color',  '#d1d2f9', 'important');
    item.style.setProperty('background-image',  'none',    'important');
    item.style.setProperty('box-shadow',        'none',    'important');
    item.style.setProperty('text-shadow',       'none',    'important');
    item.style.setProperty('color',             '#2b3350', 'important');
    item.style.setProperty('border',            '1px solid #a3bcf9', 'important');
    item.style.setProperty('border-radius',     '0.375rem', 'important');
    item.style.setProperty('font-size',         '0.8125rem');
    item.style.setProperty('font-weight',       '500');
    item.style.setProperty('padding',           '2px 0 2px 8px');
});
setTimeout(styleItems, 0); // items se añaden DESPUÉS de 'initialize', por eso usamos setTimeout
ts.on('item_add',    styleItems);
ts.on('item_remove', styleItems);

} // end if (el)
</script>
{% endif %}
{% endblock %}
