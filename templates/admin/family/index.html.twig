{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'families.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block stylesheets %}{{ parent() }}
<style>
details > summary { list-style: none; }
details > summary::-webkit-details-marker { display: none; }
details[open] > summary .tree-chevron { transform: rotate(90deg); }
.tree-chevron { transition: transform 0.15s ease; display: inline-flex; }
</style>
{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-6 flex items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="{{ path('app_educational_centre_index') }}" class="hover:text-forest-600 transition-colors">
                    {{ 'educational_centre'|trans({}, 'navigation') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'families.title'|trans({}, 'admin') }}</h1>
            {% set vy = view_year() %}
            {% if vy %}
                <p class="text-sm {{ is_viewing_past_year() ? 'text-amber-600 font-medium' : 'text-gray-500' }} mt-0.5">{{ vy.name }}</p>
            {% endif %}
        </div>
        {% if centre.activeAcademicYear %}
            <div class="flex items-center gap-2 flex-wrap">
                <a href="{{ path('app_admin_families_export', {centreId: centre.id}) }}"
                   data-controller="download-feedback"
                   data-download-feedback-message-value="{{ 'ui.export_started'|trans|e('html_attr') }}"
                   data-action="download-feedback#show"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-medium
                          text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                    {{ ux_icon('heroicons:arrow-down-tray', {class: 'h-3.5 w-3.5'}) }}
                    {{ 'families.export'|trans({}, 'admin') }}
                </a>
                {% if not is_viewing_past_year() %}
                <a href="{{ path('app_admin_families_import', {centreId: centre.id}) }}"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-medium
                          text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-3.5 w-3.5'}) }}
                    {{ 'families.import.button'|trans({}, 'admin') }}
                </a>
                {% endif %}
            </div>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:ProfessionalFamilyListComponent :centre="centre" />
    </div>

</div>
{% endblock %}
