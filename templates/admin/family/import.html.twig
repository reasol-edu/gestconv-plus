{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'families.import.title'|trans({}, 'admin') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-8">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_educational_centre_index') }}" class="hover:text-forest-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_admin_families_index', {centreId: centre.id}) }}" class="hover:text-forest-600 transition-colors">{{ 'families.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'families.import.title'|trans({}, 'admin') }}</h1>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">{{ 'families.import.title'|trans({}, 'admin') }}</h2>
        </div>
        <form method="post" enctype="multipart/form-data" class="px-6 py-6 space-y-6">
            <input type="hidden" name="_token" value="{{ csrf_token('import_oferta') }}">

            <div class="rounded-xl bg-blue-50 border border-blue-200 px-4 py-3.5 text-sm text-blue-700 space-y-1">
                <p class="font-medium">{{ 'families.import.help.title'|trans({}, 'admin') }}</p>
                <ul class="list-disc list-inside space-y-0.5 text-blue-600 text-xs mt-1">
                    <li>{{ 'families.import.help.source'|trans({}, 'admin') }}</li>
                    <li>{{ 'families.import.help.merge'|trans({}, 'admin') }}</li>
                    <li>{{ 'families.import.help.teachers'|trans({}, 'admin') }}</li>
                </ul>
            </div>

            <fieldset class="space-y-2">
                <legend class="text-sm font-medium text-gray-700">{{ 'families.import.options.title'|trans({}, 'admin') }}</legend>
                <div class="mt-2 space-y-1.5">
                    {% for key, label in {
                        'import_heads':    'families.import.options.heads',
                        'import_teachers': 'families.import.options.teachers',
                        'import_tutors':   'families.import.options.tutors'
                    } %}
                        <label class="flex items-center gap-2.5 text-sm text-gray-700 cursor-pointer">
                            <input type="checkbox" name="{{ key }}" value="1"
                                   class="h-4 w-4 rounded border-gray-300 text-forest-600 focus:ring-forest-500">
                            {{ label|trans({}, 'admin') }}
                        </label>
                    {% endfor %}
                </div>
            </fieldset>

            <div>
                <label for="json"
                       class="flex flex-col items-center justify-center gap-3 w-full rounded-xl border-2 border-dashed
                              border-gray-300 bg-gray-50 px-6 py-8 cursor-pointer
                              hover:border-forest-400 hover:bg-forest-50/40 transition-colors group mt-4 mb-2">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-8 w-8 text-gray-400 group-hover:text-forest-500 transition-colors'}) }}
                    <span class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2
                                 text-sm font-medium text-gray-700 shadow-xs group-hover:border-forest-300 group-hover:text-forest-700 transition-colors">
                        {{ 'families.import.choose_file'|trans({}, 'admin') }}
                    </span>
                    <span id="json-filename" class="text-xs text-gray-400">
                        {{ 'families.import.no_file_chosen'|trans({}, 'admin') }}
                    </span>
                </label>
                <input type="file" id="json" name="json" accept=".json,application/json" class="sr-only hidden"
                       onchange="document.getElementById('json-filename').textContent = this.files[0]?.name ?? '{{ 'families.import.no_file_chosen'|trans({}, 'admin') }}'">
            </div>

            <div class="flex items-center justify-between pt-2">
                <a href="{{ path('app_admin_families_index', {centreId: centre.id}) }}"
                   class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
                    {{ 'families.import.cancel'|trans({}, 'admin') }}
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-forest-700 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
                    {{ 'families.import.submit'|trans({}, 'admin') }}
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
