{% set sanction = entry.sanction %}
<li>
    <details class="group">
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
            <span class="text-sm text-gray-900">
                <span class="font-medium">{{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}</span>
                {% if sanction.effectiveFrom and sanction.effectiveTo %}
                    <span class="text-gray-500">— {{ sanction.effectiveFrom|date('d/m/Y') }} – {{ sanction.effectiveTo|date('d/m/Y') }}</span>
                {% endif %}
            </span>
            <span class="flex items-center gap-2 shrink-0">
                {% if entry.hasAttachments %}
                    <a href="{{ path('app_guards_sanction_attachments_zip', {sanctionId: sanction.id}) }}"
                       class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-2.5 py-1 text-xs font-medium text-gray-600 hover:border-forest-300 hover:text-forest-700 transition-colors"
                       title="{{ 'guards.download_zip'|trans({}, 'admin') }}" aria-label="{{ 'guards.download_zip'|trans({}, 'admin') }}">
                        {{ ux_icon('heroicons:archive-box-arrow-down', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                    </a>
                {% endif %}
                {{ ux_icon('heroicons:chevron-down', {class: 'h-4 w-4 text-gray-400 shrink-0 transition-transform group-open:rotate-180'}) }}
            </span>
        </summary>

        <div class="mt-3 pl-4 border-l-2 border-gray-100 space-y-4">
            {% for task in entry.tasks %}
                <div>
                    <div class="flex items-center justify-between gap-3 mb-1.5">
                        <p class="text-sm font-medium text-gray-800">{{ task.groupTeacher.subject }}</p>
                        {% if task.completedAt is null %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 text-amber-800 px-2.5 py-0.5 text-xs font-medium">
                                {{ ux_icon('heroicons:clock', {class: 'h-3 w-3'}) }}
                                {{ 'sanction_task.status.pending'|trans({}, 'admin') }}
                            </span>
                        {% elseif task.notApplicable %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 text-gray-600 px-2.5 py-0.5 text-xs font-medium">
                                {{ ux_icon('heroicons:minus-circle', {class: 'h-3 w-3'}) }}
                                {{ 'sanction_task.status.not_applicable'|trans({}, 'admin') }}
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-medium">
                                {{ ux_icon('heroicons:check-circle', {class: 'h-3 w-3'}) }}
                                {{ 'sanction_task.status.completed'|trans({}, 'admin') }}
                            </span>
                        {% endif %}
                    </div>

                    {% if task.description %}
                        <div class="prose prose-sm max-w-none text-gray-700">{{ task.description|sanitize_html('app.rich_text') }}</div>
                    {% endif %}

                    {% if task.attachments is not empty %}
                        <div class="mt-2 flex flex-wrap gap-2">
                            {% for attachment in task.attachments %}
                                <a href="{{ path('app_guards_task_attachment_download', {sanctionId: sanction.id, taskId: task.id, attachmentId: attachment.id}) }}"
                                   class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-gray-50 px-2.5 py-1.5 text-xs font-medium text-gray-700
                                          hover:border-forest-300 hover:text-forest-700 hover:bg-forest-50 transition-colors">
                                    {{ ux_icon('heroicons:paper-clip', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                                    {{ attachment.filename }}
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </details>
</li>
