{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'dashboard') }}{% endblock %}

{% block content %}
{% set active_centre  = active_centre() %}
{% set active_year    = active_centre ? active_centre.activeAcademicYear : null %}
{% set vy             = view_year() %}
{% set viewing_past   = is_viewing_past_year() %}

<div class="px-6 py-8 max-w-7xl mx-auto space-y-8">

    {# ── Encabezado ─────────────────────────────────────────────────────────── #}
    <div>
        <h1 class="text-2xl font-bold text-gray-900">
            {{ 'greeting'|trans({'%name%': app.user.name.firstName}, 'dashboard') }}
        </h1>
        {% if vy %}
            <p class="mt-1 text-sm {{ viewing_past ? 'text-amber-600 font-medium' : 'text-gray-500' }}">
                {{ 'summary_for'|trans({'%year%': vy.name}, 'dashboard') }}
            </p>
        {% elseif active_year is null %}
            <p class="mt-1 text-sm text-amber-600">
                {{ 'no_academic_year'|trans({}, 'dashboard') }}
            </p>
        {% endif %}
    </div>

    {% if active_year is null %}
    <div class="rounded-2xl border border-amber-200 bg-amber-50 px-6 py-8 text-center">
        {{ ux_icon('heroicons:exclamation-triangle', {class: 'mx-auto h-8 w-8 text-amber-400 mb-2'}) }}
        <p class="text-sm font-medium text-amber-800">{{ 'no_academic_year'|trans({}, 'dashboard') }}</p>
    </div>
    {% else %}

    {# ── Accesos rápidos: acciones principales, grandes y táctiles ──────────── #}
    {% set can_students_section = is_granted('educational_centre.section', active_centre) %}
    {% set can_sanction         = is_granted('sanction.create', active_centre) %}
    {% set can_register_absence = is_centre_admin() or belongs_to_view_year() %}
    {% set quick_action_count  = 2 + (can_sanction ? 1 : 0) + (hasTeachingGroups ? 1 : 0) + (can_register_absence ? 1 : 0) %}
    {% if not viewing_past %}
        <div id="quick-actions" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-{{ quick_action_count }} gap-3">
            <a href="{{ path('app_incidents_new') }}"
               class="flex items-center gap-3 rounded-2xl bg-forest-600 px-5 py-5 text-white shadow-xs hover:bg-forest-700 transition-colors">
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15">
                    {{ ux_icon('heroicons:document-plus', {class: 'h-6 w-6'}) }}
                </span>
                <span class="min-w-0">
                    <span class="block text-base font-semibold">{{ 'quick_action_new_report'|trans({}, 'dashboard') }}</span>
                    <span class="block text-xs text-forest-50/90 truncate">{{ 'quick_action_new_report_help'|trans({}, 'dashboard') }}</span>
                </span>
            </a>

            {% set has_pending_notify = pendingQueue.total > 0 %}
            {% if has_pending_notify %}
                <a href="{{ path('app_notifications_index') }}"
                   class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
                    <span class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
                        {{ ux_icon('heroicons:bell-alert', {class: 'h-6 w-6'}) }}
                        <span class="absolute -top-2 -right-2 flex h-6 min-w-6 items-center justify-center rounded-full bg-red-600 px-1.5 text-xs font-bold text-white shadow-xs">
                            {{ pendingQueue.total }}
                        </span>
                    </span>
                    <span class="min-w-0">
                        <span class="block text-base font-semibold text-gray-900">{{ 'quick_action_notify'|trans({}, 'dashboard') }}</span>
                        <span class="block text-xs text-gray-500 truncate">{{ 'quick_action_notify_help'|trans({}, 'dashboard') }}</span>
                    </span>
                </a>
            {% else %}
                <div class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-5 opacity-60" aria-disabled="true">
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gray-200 text-gray-400">
                        {{ ux_icon('heroicons:bell-alert', {class: 'h-6 w-6'}) }}
                    </span>
                    <span class="min-w-0">
                        <span class="block text-base font-semibold text-gray-500">{{ 'quick_action_notify'|trans({}, 'dashboard') }}</span>
                        <span class="block text-xs text-gray-400 truncate">{{ 'quick_action_notify_none'|trans({}, 'dashboard') }}</span>
                    </span>
                </div>
            {% endif %}

            {% if can_sanction %}
                {% if sanctionableCount > 0 %}
                    <a href="{{ path('app_sanctions_new') }}"
                       class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
                        <span class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-red-50 text-red-500">
                            {{ ux_icon('heroicons:scale', {class: 'h-6 w-6'}) }}
                            <span class="absolute -top-2 -right-2 flex h-6 min-w-6 items-center justify-center rounded-full bg-red-600 px-1.5 text-xs font-bold text-white shadow-xs">
                                {{ sanctionableCount }}
                            </span>
                        </span>
                        <span class="min-w-0">
                            <span class="block text-base font-semibold text-gray-900">{{ 'quick_action_new_sanction'|trans({}, 'dashboard') }}</span>
                            <span class="block text-xs text-gray-500 truncate">{{ 'quick_action_new_sanction_help'|trans({}, 'dashboard') }}</span>
                        </span>
                    </a>
                {% else %}
                    <div class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-5 opacity-60" aria-disabled="true">
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gray-200 text-gray-400">
                            {{ ux_icon('heroicons:scale', {class: 'h-6 w-6'}) }}
                        </span>
                        <span class="min-w-0">
                            <span class="block text-base font-semibold text-gray-500">{{ 'quick_action_new_sanction'|trans({}, 'dashboard') }}</span>
                            <span class="block text-xs text-gray-400 truncate">{{ 'quick_action_new_sanction_none'|trans({}, 'dashboard') }}</span>
                        </span>
                    </div>
                {% endif %}
            {% endif %}

            {% if hasTeachingGroups %}
                {% if pendingSanctionTasksCount > 0 %}
                    <a href="{{ path('app_sanction_tasks_index') }}"
                       class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
                        <span class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
                            {{ ux_icon('heroicons:clipboard-document-list', {class: 'h-6 w-6'}) }}
                            <span class="absolute -top-2 -right-2 flex h-6 min-w-6 items-center justify-center rounded-full bg-red-600 px-1.5 text-xs font-bold text-white shadow-xs">
                                {{ pendingSanctionTasksCount }}
                            </span>
                        </span>
                        <span class="min-w-0">
                            <span class="block text-base font-semibold text-gray-900">{{ 'quick_action_pending_tasks'|trans({}, 'dashboard') }}</span>
                            <span class="block text-xs text-gray-500 truncate">{{ 'quick_action_pending_tasks_help'|trans({}, 'dashboard') }}</span>
                        </span>
                    </a>
                {% else %}
                    <div class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-5 opacity-60" aria-disabled="true">
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gray-200 text-gray-400">
                            {{ ux_icon('heroicons:clipboard-document-list', {class: 'h-6 w-6'}) }}
                        </span>
                        <span class="min-w-0">
                            <span class="block text-base font-semibold text-gray-500">{{ 'quick_action_pending_tasks'|trans({}, 'dashboard') }}</span>
                            <span class="block text-xs text-gray-400 truncate">{{ 'quick_action_pending_tasks_none'|trans({}, 'dashboard') }}</span>
                        </span>
                    </div>
                {% endif %}
            {% endif %}

            {% if can_register_absence %}
                <a href="{{ path('app_absences_new') }}"
                   class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
                        {{ ux_icon('heroicons:user-minus', {class: 'h-6 w-6'}) }}
                    </span>
                    <span class="min-w-0">
                        <span class="block text-base font-semibold text-gray-900">{{ 'quick_action_new_absence'|trans({}, 'dashboard') }}</span>
                        <span class="block text-xs text-gray-500 truncate">{{ (is_centre_admin() ? 'quick_action_new_absence_help_admin' : 'quick_action_new_absence_help_self')|trans({}, 'dashboard') }}</span>
                    </span>
                </a>
            {% endif %}
        </div>
    {% endif %}

    {# ── Tarjetas estadísticas, o avisos de configuración pendiente del curso ── #}
    {% if can_students_section and groupCount == 0 %}
        <div class="rounded-2xl border border-gray-200 bg-white px-6 py-12 text-center">
            {{ ux_icon('heroicons:squares-2x2', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm font-medium text-gray-700">{{ 'no_groups_defined'|trans({}, 'dashboard') }}</p>
            {% if not viewing_past %}
                <a href="{{ path('app_centre_offer_index', {centreId: active_centre.id}) }}"
                   class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-4 py-2 text-sm font-medium text-white shadow-xs hover:bg-forest-700 transition-colors">
                    {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    {{ 'action_manage_offer'|trans({}, 'dashboard') }}
                </a>
            {% endif %}
        </div>
    {% else %}
    {% if can_students_section and teacherCount == 0 %}
        <div class="rounded-2xl border border-gray-200 bg-white px-6 py-8 text-center">
            {{ ux_icon('heroicons:user-group', {class: 'mx-auto h-8 w-8 text-gray-300 mb-2'}) }}
            <p class="text-sm font-medium text-gray-700">{{ 'no_teachers_registered'|trans({}, 'dashboard') }}</p>
            {% if not viewing_past %}
                <a href="{{ path('app_centre_teachers_index', {centreId: active_centre.id}) }}"
                   class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-4 py-2 text-sm font-medium text-white shadow-xs hover:bg-forest-700 transition-colors">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
                    {{ 'action_manage_teachers'|trans({}, 'dashboard') }}
                </a>
            {% endif %}
        </div>
    {% endif %}
    {% if studentCount == 0 %}
        <div class="rounded-2xl border border-gray-200 bg-white px-6 py-12 text-center">
            {{ ux_icon('heroicons:academic-cap', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm font-medium text-gray-700">{{ 'no_students_registered'|trans({}, 'dashboard') }}</p>
            {% if can_students_section and not viewing_past %}
                <a href="{{ path('app_centre_students_import', {centreId: active_centre.id}) }}"
                   class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-4 py-2 text-sm font-medium text-white shadow-xs hover:bg-forest-700 transition-colors">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
                    {{ 'action_import_students'|trans({}, 'dashboard') }}
                </a>
            {% endif %}
        </div>
    {% else %}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <a href="{{ path('app_incidents_index') }}" class="col-span-1 block rounded-2xl border border-gray-200 bg-white p-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                    {{ 'incident_reports'|trans({}, 'dashboard') }}
                </p>
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-50 text-red-500">
                    {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-4.5 w-4.5'}) }}
                </span>
            </div>
            <p class="mt-3 text-3xl font-bold text-gray-900 tabular-nums">{{ reportCount30d }}</p>
            <p class="mt-1 text-xs text-gray-500">{{ 'incidents_last_30_days'|trans({}, 'dashboard') }}</p>
        </a>

        <a href="{{ path('app_sanctions_index') }}" class="col-span-1 block rounded-2xl border border-gray-200 bg-white p-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                    {{ 'active_sanctions'|trans({}, 'dashboard') }}
                </p>
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-50 text-amber-600">
                    {{ ux_icon('heroicons:scale', {class: 'h-4.5 w-4.5'}) }}
                </span>
            </div>
            <p class="mt-3 text-3xl font-bold text-gray-900 tabular-nums">{{ activeSanctionsCount }}</p>
            <p class="mt-1 text-xs text-gray-500">{{ 'active_sanctions_help'|trans({}, 'dashboard') }}</p>
        </a>

        {% if showPrescriptionWarning %}
        {% set has_pending_prescription = pendingPrescriptionCount > 0 %}
        <a href="{{ path('app_notifications_index') }}" class="col-span-1 block rounded-2xl border border-gray-200 bg-white p-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                    {{ 'pending_prescription'|trans({}, 'dashboard') }}
                </p>
                <span class="flex h-8 w-8 items-center justify-center rounded-lg {{ has_pending_prescription ? 'bg-red-50 text-red-500' : 'bg-green-50 text-green-600' }}">
                    {{ ux_icon(has_pending_prescription ? 'heroicons:clock' : 'heroicons:check-circle', {class: 'h-4.5 w-4.5'}) }}
                </span>
            </div>
            <p class="mt-3 text-3xl font-bold tabular-nums {{ has_pending_prescription ? 'text-red-600' : 'text-green-600' }}">{{ pendingPrescriptionCount }}</p>
            <p class="mt-1 text-xs text-gray-500">
                {{ (has_pending_prescription ? 'pending_prescription_help' : 'pending_prescription_none')|trans({}, 'dashboard') }}
            </p>
        </a>
        {% endif %}

        {% if hasFullAccess or tutoredGroups|length > 0 %}
        {% set has_incomplete_tasks = sanctionsWithIncompleteTasksCount > 0 %}
        <a href="{{ path('app_sanctions_index') }}?pendingTasksOnly=1" class="col-span-1 block rounded-2xl border border-gray-200 bg-white p-5 shadow-xs hover:border-forest-300 hover:shadow-sm transition">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                    {{ 'sanctions_with_incomplete_tasks'|trans({}, 'dashboard') }}
                </p>
                <span class="flex h-8 w-8 items-center justify-center rounded-lg {{ has_incomplete_tasks ? 'bg-red-50 text-red-500' : 'bg-green-50 text-green-600' }}">
                    {{ ux_icon(has_incomplete_tasks ? 'heroicons:clipboard-document-list' : 'heroicons:check-circle', {class: 'h-4.5 w-4.5'}) }}
                </span>
            </div>
            <p class="mt-3 text-3xl font-bold tabular-nums {{ has_incomplete_tasks ? 'text-red-600' : 'text-green-600' }}">{{ sanctionsWithIncompleteTasksCount }}</p>
            <p class="mt-1 text-xs text-gray-500">
                {{ (has_incomplete_tasks ? 'sanctions_with_incomplete_tasks_help' : 'sanctions_with_incomplete_tasks_none')|trans({}, 'dashboard') }}
            </p>
        </a>
        {% endif %}
    </div>
    {% endif %}
    {% endif %}

    {# ── Sanciones en vigor en tus grupos (esta semana / próxima) ──────────── #}
    {% if hasTeachingGroups or thisWeekSanctions|length > 0 or nextWeekSanctions|length > 0 %}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="flex items-center justify-between border-b border-gray-100 px-5 py-3.5">
            <h2 class="text-sm font-semibold text-gray-800 flex items-center gap-2">
                {{ ux_icon('heroicons:calendar-days', {class: 'h-4 w-4 text-gray-400'}) }}
                {{ 'active_sanctions_week_title'|trans({}, 'dashboard') }}
            </h2>
            <a href="{{ path('app_sanctions_index') }}" class="text-xs font-medium text-forest-700 hover:text-forest-800">
                {{ 'recent_reports_view_all'|trans({}, 'dashboard') }}
            </a>
        </div>

        <div class="grid grid-cols-1 divide-y divide-gray-100 sm:grid-cols-2 sm:divide-y-0 sm:divide-x">
            {% for week in [
                {label: 'active_sanctions_this_week'|trans({}, 'dashboard'), sanctions: thisWeekSanctions},
                {label: 'active_sanctions_next_week'|trans({}, 'dashboard'), sanctions: nextWeekSanctions},
            ] %}
            <div>
                <p class="px-5 py-2.5 text-xs font-semibold uppercase tracking-wide text-gray-400 border-b border-gray-100">
                    {{ week.label }}
                </p>
                {% if week.sanctions|length == 0 %}
                    <p class="px-5 py-6 text-center text-sm text-gray-400">
                        {{ 'active_sanctions_week_empty'|trans({}, 'dashboard') }}
                    </p>
                {% else %}
                    <ul class="divide-y divide-gray-100">
                        {% for sanction in week.sanctions %}
                            <li>
                                <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
                                   class="flex items-start justify-between gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
                                    <div class="min-w-0">
                                        <p class="truncate text-sm font-medium text-gray-800">
                                            {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
                                        </p>
                                        <p class="mt-0.5 text-xs text-gray-500">{{ sanction.group.name }}</p>
                                        {% if sanction.noMeasureApplied %}
                                            <span class="mt-1 inline-flex items-center rounded-full bg-gray-100 text-gray-500 px-2 py-0.5 text-[11px] font-medium">
                                                {{ 'sanction.badge.no_measure'|trans({}, 'admin') }}
                                            </span>
                                        {% else %}
                                            <div class="mt-1 flex flex-wrap gap-1">
                                                {% for measure in sanction.measures %}
                                                    <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-700 px-2 py-0.5 text-[11px] font-medium">
                                                        {{ measure.name }}
                                                    </span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    {% if sanction.effectiveFrom %}
                                        <p class="shrink-0 text-right text-[11px] text-gray-400 tabular-nums whitespace-nowrap">
                                            {{ sanction.effectiveFrom|date('d/m') }}
                                            {% if sanction.effectiveTo and sanction.effectiveTo != sanction.effectiveFrom %}
                                                – {{ sanction.effectiveTo|date('d/m') }}
                                            {% endif %}
                                        </p>
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ── Últimos partes + panel condicional por rol (requieren estudiantado matriculado) ── #}
    {% set show_recent_reports = studentCount > 0 %}
    {% set show_top_students   = hasFullAccess and studentCount > 0 %}
    {% set show_tutored_groups = not hasFullAccess and tutoredGroups|length > 0 %}
    {% if show_recent_reports or show_top_students or show_tutored_groups %}
    <div class="grid grid-cols-1 gap-6 {{ (show_recent_reports and (show_top_students or show_tutored_groups)) ? 'lg:grid-cols-3' : '' }}">

        {% if show_recent_reports %}
        <div class="{{ (show_top_students or show_tutored_groups) ? 'lg:col-span-2' : '' }} rounded-2xl border border-gray-200 bg-white shadow-xs">
            <div class="flex items-center justify-between border-b border-gray-100 px-5 py-3.5">
                <h2 class="text-sm font-semibold text-gray-800">{{ 'recent_reports_title'|trans({}, 'dashboard') }}</h2>
                <a href="{{ path('app_incidents_index') }}" class="text-xs font-medium text-forest-700 hover:text-forest-800">
                    {{ 'recent_reports_view_all'|trans({}, 'dashboard') }}
                </a>
            </div>
            {% if recentReports|length == 0 %}
                <p class="px-5 py-8 text-center text-sm text-gray-500">{{ 'recent_reports_empty'|trans({}, 'dashboard') }}</p>
            {% else %}
                <ul class="divide-y divide-gray-100">
                    {% for report in recentReports %}
                        <li>
                            <a href="{{ path('app_incidents_show', {id: report.id}) }}" class="flex items-center justify-between gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
                                <div class="min-w-0">
                                    <p class="truncate text-sm font-medium text-gray-800">
                                        {{ report.student.name.lastName }}, {{ report.student.name.firstName }}
                                    </p>
                                    <p class="mt-0.5 text-xs text-gray-500">{{ report.group.name }} · {{ report.occurredAt|date('d/m/Y') }}</p>
                                </div>
                                {% if report.isNotified %}
                                    <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-green-100 text-green-700 px-2 py-0.5 text-[11px] font-medium">
                                        {{ ux_icon('heroicons:check-circle', {class: 'h-3 w-3'}) }}
                                        {{ 'notification.badge.notified'|trans({}, 'notifications') }}
                                    </span>
                                {% else %}
                                    <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-[11px] font-medium">
                                        {{ ux_icon('heroicons:bell-alert', {class: 'h-3 w-3'}) }}
                                        {{ 'notification.badge.pending'|trans({}, 'notifications') }}
                                    </span>
                                {% endif %}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
        {% endif %}

        {% if show_top_students %}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
            <div class="flex items-center justify-between border-b border-gray-100 px-5 py-3.5">
                <h2 class="text-sm font-semibold text-gray-800">{{ 'top_students_title'|trans({}, 'dashboard') }}</h2>
                <a href="{{ path('app_sanctions_index') }}" class="text-xs font-medium text-forest-700 hover:text-forest-800">
                    {{ 'recent_reports_view_all'|trans({}, 'dashboard') }}
                </a>
            </div>
            {% if topStudents|length == 0 %}
                <p class="px-5 py-8 text-center text-sm text-gray-500">{{ 'top_students_empty'|trans({}, 'dashboard') }}</p>
            {% else %}
                <ul class="divide-y divide-gray-100">
                    {% for row in topStudents %}
                        <li>
                            <a href="{{ path('app_students_show', {id: row.studentId}) }}"
                               class="flex items-center justify-between gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
                                <div class="min-w-0">
                                    <p class="truncate text-sm font-medium text-gray-800">{{ row.lastName }}, {{ row.firstName }}</p>
                                    <p class="mt-0.5 text-xs text-gray-500">{{ row.groupName }}</p>
                                </div>
                                <div class="shrink-0 text-right">
                                    <p class="text-sm font-semibold text-gray-800 tabular-nums">{{ row.sanctionableCount }}</p>
                                    {% if row.seriousCount > 0 %}
                                        <p class="text-[11px] text-red-600">{{ row.seriousCount }} {{ 'top_students_col_serious'|trans({}, 'dashboard') }}</p>
                                    {% endif %}
                                </div>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
        {% elseif show_tutored_groups %}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
            <div class="border-b border-gray-100 px-5 py-3.5">
                <h2 class="text-sm font-semibold text-gray-800">{{ 'tutored_groups_title'|trans({}, 'dashboard') }}</h2>
            </div>
            <ul class="divide-y divide-gray-100">
                {% for entry in tutoredGroups %}
                    <li class="flex items-center justify-between gap-3 px-5 py-3">
                        <p class="truncate text-sm font-medium text-gray-800">{{ entry.group.name }}</p>
                        <p class="shrink-0 text-xs text-gray-500">{{ entry.students }} {{ 'tutored_groups_students'|trans({}, 'dashboard') }}</p>
                    </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {% endif %}

</div>
{% endblock %}
