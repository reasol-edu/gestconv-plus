{#
 # Macros for server-side SVG charts on the dashboard.
 # family_bars        – horizontal bars: total (gray) / occupied (amber) / signed (emerald)
 # student_state_bars – stacked horizontal bars of students by family and position state
 #}

{%- macro family_bars(stats) -%}
    {%- set maxTotal = 0 -%}
    {%- for stat in stats -%}
        {%- if stat.total > maxTotal -%}{%- set maxTotal = stat.total -%}{%- endif -%}
    {%- endfor -%}

    {%- if stats|length == 0 or maxTotal == 0 -%}
        <p class="py-8 text-center text-sm text-gray-400">
            {{- 'no_family_data'|trans({}, 'dashboard') -}}
        </p>
    {%- else -%}
        {%- set n = stats|length -%}
        {%- set svgH = n * 32 + 16 -%}
        <svg viewBox="0 0 480 {{ svgH }}" xmlns="http://www.w3.org/2000/svg"
             class="w-full" role="img" aria-label="{{ 'positions_by_family'|trans({}, 'dashboard') }}">
            {%- for stat in stats -%}
                {%- set ry = loop.index0 * 32 + 8 -%}
                {%- set wTotal    = stat.total    / maxTotal * 320 -%}
                {%- set wOccupied = stat.occupied / maxTotal * 320 -%}
                {%- set wSigned   = stat.signed   / maxTotal * 320 -%}
                <text x="138" y="{{ ry + 8 }}" dominant-baseline="middle" text-anchor="end"
                      font-size="11" fill="#6b7280">
                    {{- stat.family_name|length > 22 ? stat.family_name|slice(0, 22) ~ '…' : stat.family_name -}}
                </text>
                <rect x="148" y="{{ ry }}" width="{{ wTotal }}" height="16" rx="0" fill="#e5e7eb">
                    <title>{{ stat.family_name }}: {{ 'chart_tooltip_total'|trans({'%count%': stat.total}, 'dashboard') }}</title>
                </rect>
                {%- if stat.occupied > 0 -%}
                <rect x="148" y="{{ ry }}" width="{{ wOccupied }}" height="16" rx="0" fill="#fbbf24">
                    <title>{{ stat.family_name }}: {{ 'chart_tooltip_occupied'|trans({'%count%': stat.occupied}, 'dashboard') }}</title>
                </rect>
                {%- endif -%}
                {%- if stat.signed > 0 -%}
                <rect x="148" y="{{ ry }}" width="{{ wSigned }}" height="16" rx="0" fill="#34d399">
                    <title>{{ stat.family_name }}: {{ 'chart_tooltip_signed'|trans({'%count%': stat.signed}, 'dashboard') }}</title>
                </rect>
                {%- endif -%}
                {# Labels inside each visible segment #}
                {%- if wSigned > 14 -%}
                <text x="{{ 148 + wSigned - 4 }}" y="{{ ry + 8 }}" dominant-baseline="middle"
                      text-anchor="end" font-size="9" font-weight="bold" fill="white">
                    {{- stat.signed -}}
                </text>
                {%- endif -%}
                {%- if wOccupied - wSigned > 14 -%}
                <text x="{{ 148 + wOccupied - 4 }}" y="{{ ry + 8 }}" dominant-baseline="middle"
                      text-anchor="end" font-size="9" font-weight="bold" fill="white">
                    {{- stat.occupied -}}
                </text>
                {%- endif -%}
                {%- if wTotal - wOccupied > 14 -%}
                <text x="{{ 148 + wTotal - 4 }}" y="{{ ry + 8 }}" dominant-baseline="middle"
                      text-anchor="end" font-size="9" font-weight="bold" fill="#9ca3af">
                    {{- stat.total -}}
                </text>
                {%- endif -%}
            {%- endfor -%}
        </svg>
    {%- endif -%}
{%- endmacro -%}

{%- macro student_state_bars(stats) -%}
    {%- set segments = [
        {'key': 'unassigned', 'color': '#9ca3af', 'tooltip': 'chart_tooltip_unassigned'},
        {'key': 'draft',      'color': '#f59e0b', 'tooltip': 'chart_tooltip_draft'},
        {'key': 'pending',    'color': '#3b82f6', 'tooltip': 'chart_tooltip_pending'},
        {'key': 'registered', 'color': '#10b981', 'tooltip': 'chart_tooltip_registered'},
        {'key': 'signed',     'color': '#876baf', 'tooltip': 'chart_tooltip_signed_student'},
    ] -%}
    {%- set maxTotal = 0 -%}
    {%- for stat in stats -%}
        {%- set rowTotal = stat.unassigned + stat.draft + stat.pending + stat.registered + stat.signed -%}
        {%- if rowTotal > maxTotal -%}{%- set maxTotal = rowTotal -%}{%- endif -%}
    {%- endfor -%}

    {%- if stats|length == 0 or maxTotal == 0 -%}
        <p class="py-8 text-center text-sm text-gray-400">
            {{- 'no_student_data'|trans({}, 'dashboard') -}}
        </p>
    {%- else -%}
        {%- set n = stats|length -%}
        {%- set svgH = n * 32 + 16 -%}
        <svg viewBox="0 0 480 {{ svgH }}" xmlns="http://www.w3.org/2000/svg"
             class="w-full" role="img" aria-label="{{ 'students_by_family'|trans({}, 'dashboard') }}">
            {%- for stat in stats -%}
                {%- set ry = loop.index0 * 32 + 8 -%}
                {%- set rowTotal = stat.unassigned + stat.draft + stat.pending + stat.registered + stat.signed -%}
                <text x="138" y="{{ ry + 8 }}" dominant-baseline="middle" text-anchor="end"
                      font-size="11" fill="#6b7280">
                    {{- stat.family_name|length > 22 ? stat.family_name|slice(0, 22) ~ '…' : stat.family_name -}}
                </text>
                {%- if rowTotal == 0 -%}
                    <rect x="148" y="{{ ry }}" width="2" height="16" fill="#e5e7eb"/>
                {%- else -%}
                    {%- set cursor = 148 -%}
                    {%- for seg in segments -%}
                        {%- set value = attribute(stat, seg.key) -%}
                        {%- if value > 0 -%}
                            {%- set w = value / maxTotal * 320 -%}
                            <rect x="{{ cursor }}" y="{{ ry }}" width="{{ w }}" height="16" fill="{{ seg.color }}">
                                <title>{{ stat.family_name }}: {{ (seg.tooltip)|trans({'%count%': value}, 'dashboard') }}</title>
                            </rect>
                            {%- if w > 14 -%}
                            <text x="{{ cursor + w / 2 }}" y="{{ ry + 8 }}" dominant-baseline="middle"
                                  text-anchor="middle" font-size="9" font-weight="bold"
                                  fill="{{ seg.key == 'unassigned' ? '#374151' : 'white' }}">
                                {{- value -}}
                            </text>
                            {%- endif -%}
                            {%- set cursor = cursor + w -%}
                        {%- endif -%}
                    {%- endfor -%}
                {%- endif -%}
            {%- endfor -%}
        </svg>
    {%- endif -%}
{%- endmacro -%}
