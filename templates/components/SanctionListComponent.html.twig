{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes }}>
    {% set pagination = this.pagination %}
    {% set taskCounts = this.taskCompletionCounts %}

    {# Barra de filtros #}
    <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50 flex flex-wrap items-center gap-3">

        {# Búsqueda libre #}
        <div class="relative flex-1 min-w-48">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
            </div>
            <input type="search"
                   data-model="norender|search"
                   data-action="input->live#action"
                   data-live-action-param="resetPage"
                   placeholder="{{ 'sanction.filter.search_placeholder'|trans({}, 'admin') }}"
                   value="{{ search }}"
                   class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                          text-gray-900 placeholder-gray-400 focus:border-forest-500 focus:outline-none
                          focus:ring-3 focus:ring-forest-500/20 transition-colors">
        </div>

        {# Vigentes hoy #}
        <button data-action="live#action" data-live-action-param="toggleEffectiveToday"
                class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-2 text-xs font-medium transition-colors shrink-0
                       {{ effectiveToday ? 'border-forest-300 bg-forest-50 text-forest-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50' }}">
            {{ ux_icon('heroicons:calendar-days', {class: 'h-3.5 w-3.5'}) }}
            {{ 'sanction.filter.effective_today'|trans({}, 'admin') }}
        </button>

        {# Pendientes de notificar #}
        <button data-action="live#action" data-live-action-param="togglePendingOnly"
                class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-2 text-xs font-medium transition-colors shrink-0
                       {{ pendingOnly ? 'border-forest-300 bg-forest-50 text-forest-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50' }}">
            {{ ux_icon('heroicons:bell-alert', {class: 'h-3.5 w-3.5'}) }}
            {{ 'sanction.filter.pending_notification'|trans({}, 'admin') }}
        </button>

        {# Con materias sin cumplimentar #}
        <button data-action="live#action" data-live-action-param="togglePendingTasksOnly"
                class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-2 text-xs font-medium transition-colors shrink-0
                       {{ pendingTasksOnly ? 'border-forest-300 bg-forest-50 text-forest-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50' }}">
            {{ ux_icon('heroicons:clipboard-document-list', {class: 'h-3.5 w-3.5'}) }}
            {{ 'sanction.filter.pending_tasks'|trans({}, 'admin') }}
        </button>

        <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:scale', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm text-gray-500">
                {{ (this.hasActiveFilters ? 'sanction.search_empty' : 'sanction.empty')|trans({}, 'admin') }}
            </p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.student'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.measures'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.effective_period'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.tasks'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.notified'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'sanction.col.created_at'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for sanction in pagination.items %}
                        {% set taskSummary = taskCounts[sanction.id.toRfc4122] ?? null %}
                        {% set tasksIncomplete = taskSummary is not null and taskSummary.completed < taskSummary.total %}
                        <tr class="hover:bg-gray-50 transition-colors {{ tasksIncomplete ? 'bg-amber-50/60' : '' }}">
                            <td data-label="{{ 'sanction.col.student'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4 font-medium text-gray-900">
                                {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
                                <div class="font-normal text-xs text-gray-500">{{ sanction.group.name }}</div>
                                {% if sanction.registeredInSeneca is same as true or
                                      (not sanction.noMeasureApplied and (sanction.measuresEffective is same as false or sanction.familyClaimed is same as true)) %}
                                    <div class="flex flex-wrap gap-1 mt-1">
                                        {% if sanction.registeredInSeneca is same as true %}
                                            <span class="inline-flex items-center gap-0.5 rounded-full bg-sky-100 text-sky-700 px-2 py-0.5 text-xs font-medium">
                                                {{ ux_icon('heroicons:check-badge', {class: 'h-3 w-3'}) }}
                                                {{ 'sanction.badge.in_seneca'|trans({}, 'admin') }}
                                            </span>
                                        {% endif %}
                                        {% if not sanction.noMeasureApplied and sanction.measuresEffective is same as false %}
                                            <span class="inline-flex items-center gap-0.5 rounded-full bg-red-100 text-red-700 px-2 py-0.5 text-xs font-medium">
                                                {{ ux_icon('heroicons:x-circle', {class: 'h-3 w-3'}) }}
                                                {{ 'sanction.badge.not_effective'|trans({}, 'admin') }}
                                            </span>
                                        {% endif %}
                                        {% if not sanction.noMeasureApplied and sanction.familyClaimed is same as true %}
                                            <span class="inline-flex items-center gap-0.5 rounded-full bg-amber-100 text-amber-700 px-2 py-0.5 text-xs font-medium">
                                                {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-3 w-3'}) }}
                                                {{ 'sanction.badge.family_claimed'|trans({}, 'admin') }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.measures'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4">
                                {% if sanction.noMeasureApplied %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-500 px-2.5 py-0.5 text-xs font-medium">
                                        {{ 'sanction.badge.no_measure'|trans({}, 'admin') }}
                                    </span>
                                {% else %}
                                    <div class="flex flex-wrap gap-1">
                                        {% for measure in sanction.measures %}
                                            <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-700 px-2.5 py-0.5 text-xs font-medium">
                                                {{ measure.name }}
                                            </span>
                                        {% else %}
                                            <span class="text-xs text-gray-400">—</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.effective_period'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4 text-gray-600 text-xs">
                                {% if sanction.effectiveFrom and sanction.effectiveTo %}
                                    {{ sanction.effectiveFrom|date('d/m/Y') }} – {{ sanction.effectiveTo|date('d/m/Y') }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.tasks'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4">
                                {% if taskSummary is not null %}
                                    <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium
                                                 {{ tasksIncomplete ? 'bg-amber-100 text-amber-800' : 'bg-green-100 text-green-700' }}">
                                        {{ ux_icon(tasksIncomplete ? 'heroicons:clock' : 'heroicons:check-circle', {class: 'h-3 w-3'}) }}
                                        {{ taskSummary.completed }}/{{ taskSummary.total }}
                                    </span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.notified'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4">
                                {% if sanction.notified %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 text-green-700 px-2 py-0.5 text-xs font-medium">
                                        {{ ux_icon('heroicons:check-circle', {class: 'h-3 w-3'}) }}
                                        {{ 'notification.badge.notified'|trans({}, 'notifications') }}
                                    </span>
                                {% elseif is_granted('sanction.notify', sanction) and not is_viewing_past_year() %}
                                    <a href="{{ path('app_notifications_register_sanction', {id: sanction.id}) }}"
                                       class="inline-flex items-center gap-1 rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-xs font-medium hover:bg-amber-200 transition-colors">
                                        {{ ux_icon('heroicons:bell-alert', {class: 'h-3 w-3'}) }}
                                        {{ 'notification.badge.pending'|trans({}, 'notifications') }}
                                    </a>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-xs font-medium">
                                        {{ ux_icon('heroicons:bell-alert', {class: 'h-3 w-3'}) }}
                                        {{ 'notification.badge.pending'|trans({}, 'notifications') }}
                                    </span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.created_at'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-4 text-gray-500 text-xs">
                                {{ sanction.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
                                   class="inline-flex items-center gap-1 rounded-lg border border-gray-200 px-2.5 py-1.5 text-xs font-medium text-gray-700
                                          hover:bg-gray-50 transition-colors">
                                    {{ ux_icon('heroicons:eye', {class: 'h-3.5 w-3.5'}) }}
                                    {{ 'sanction.view'|trans({}, 'admin') }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {{ pager.nav(pagination) }}
    {% endif %}
    </div>
</div>
