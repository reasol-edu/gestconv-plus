{# Tabla de marcadores disponibles en los campos de texto enriquecido de personalización de informes.
   Se usa desde el popover de ayuda (icono ⓘ) en SettingsComponent y debe reflejar los marcadores
   que resuelve App\Service\PdfHeaderBuilder. #}
{% set placeholderRows = [
    {marker: '{title}', description: 'settings.placeholder_help.marker.title', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{report_nr}', description: 'settings.placeholder_help.marker.report_nr', scope: 'settings.placeholder_help.scope.reports_only'},
    {marker: '{student_name}', description: 'settings.placeholder_help.marker.student_name', scope: 'settings.placeholder_help.scope.reports_and_sanctions'},
    {marker: '{group_name}', description: 'settings.placeholder_help.marker.group_name', scope: 'settings.placeholder_help.scope.reports_and_sanctions'},
    {marker: '{centre_name}', description: 'settings.placeholder_help.marker.centre_name', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{academic_year}', description: 'settings.placeholder_help.marker.academic_year', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{date_from} / {date_to}', description: 'settings.placeholder_help.marker.date_range', scope: 'settings.placeholder_help.scope.group_stats_only'},
    {marker: '{city}', description: 'settings.placeholder_help.marker.city', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{current_date}', description: 'settings.placeholder_help.marker.current_date', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{current_time}', description: 'settings.placeholder_help.marker.current_time', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{current_day}', description: 'settings.placeholder_help.marker.current_day', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{current_month_name}', description: 'settings.placeholder_help.marker.current_month_name', scope: 'settings.placeholder_help.scope.all'},
    {marker: '{current_year}', description: 'settings.placeholder_help.marker.current_year', scope: 'settings.placeholder_help.scope.all'},
] %}

<div class="w-[26rem] max-w-[90vw] p-3">
    <p class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">
        {{ 'settings.placeholder_help.title'|trans({}, 'settings') }}
    </p>
    <p class="text-xs text-gray-500 mb-3">
        {{ 'settings.placeholder_help.intro'|trans({}, 'settings') }}
    </p>

    <table class="w-full text-xs">
        <thead>
            <tr class="text-left text-gray-400">
                <th class="pb-1 pr-2 font-medium">{{ 'settings.placeholder_help.column.marker'|trans({}, 'settings') }}</th>
                <th class="pb-1 pr-2 font-medium">{{ 'settings.placeholder_help.column.description'|trans({}, 'settings') }}</th>
                <th class="pb-1 font-medium">{{ 'settings.placeholder_help.column.scope'|trans({}, 'settings') }}</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for row in placeholderRows %}
                <tr class="align-top">
                    <td class="py-1.5 pr-2 font-mono text-forest-700 whitespace-nowrap">{{ row.marker }}</td>
                    <td class="py-1.5 pr-2 text-gray-600">{{ row.description|trans({}, 'settings') }}</td>
                    <td class="py-1.5 text-gray-500 whitespace-nowrap">{{ row.scope|trans({}, 'settings') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <p class="text-xs text-gray-500 mt-3 pt-2 border-t border-gray-100">
        {{ 'settings.placeholder_help.footer_default_note'|trans({}, 'settings') }}
    </p>
</div>
