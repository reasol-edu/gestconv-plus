{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes }}>
    {% set pagination = this.pagination %}

    {# Barra de búsqueda #}
    <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50 flex items-center gap-3">
        <div class="relative flex-1 max-w-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
            </div>
            <input type="search"
                   data-model="norender|search"
                   data-action="input->live#action"
                   data-live-action-param="resetPage"
                   placeholder="{{ 'sanction.filter.search_placeholder'|trans({}, 'admin') }}"
                   value="{{ search }}"
                   class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                          text-gray-900 placeholder-gray-400 focus:border-forest-500 focus:outline-none
                          focus:ring-3 focus:ring-forest-500/20 transition-colors">
        </div>

        <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:user-group', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm text-gray-500">
                {{ (search != '' ? 'sanction.empty_search' : 'sanction.empty_students')|trans({}, 'admin') }}
            </p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="table-cards min-w-full divide-y divide-gray-100 text-sm">
                <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-500">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left">{{ 'sanction.col.student'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-4 py-3 text-left">{{ 'sanction.col.group'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-4 py-3 text-center">{{ 'sanction.col.sanctionable'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-4 py-3 text-center">{{ 'sanction.col.serious_abbr'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-4 py-3 text-center">{{ 'sanction.col.prescribed'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    {% for row in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'sanction.col.student'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-6 py-3 font-medium text-gray-900 whitespace-nowrap">
                                {{ row.lastName }}, {{ row.firstName }}
                            </td>
                            <td data-label="{{ 'sanction.col.group'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-4 py-3 text-gray-600 whitespace-nowrap">
                                {{ row.groupName }}
                            </td>
                            <td data-label="{{ 'sanction.col.sanctionable'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-4 py-3 text-left sm:text-center">
                                {% if row.sanctionableCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">
                                        {{ row.sanctionableCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.serious_abbr'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-4 py-3 text-left sm:text-center">
                                {% if row.seriousCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-700">
                                        {{ row.seriousCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'sanction.col.prescribed'|trans({}, 'admin')|e('html_attr') }}"
                                class="px-4 py-3 text-left sm:text-center">
                                {% if row.prescribedCount > 0 %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500">
                                        {{ row.prescribedCount }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-300">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a href="{{ path('app_sanctions_new', {studentId: row.studentId, groupId: row.groupId}) }}"
                                   class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                          hover:bg-forest-700 transition-colors shadow-xs">
                                    {{ ux_icon('heroicons:plus', {class: 'h-3.5 w-3.5'}) }}
                                    {{ 'sanction.new'|trans({}, 'admin') }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {{ pager.nav(pagination) }}
    {% endif %}
    </div>
</div>
