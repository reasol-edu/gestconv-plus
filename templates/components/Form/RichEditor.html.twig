{% props id, name, label, value = '', placeholder = '', help = null, required = false, error = null %}
<div>
    <label class="block text-sm font-medium text-gray-700 mb-1.5">
        {{ label }}{% if required %} <span class="text-red-500" aria-hidden="true">*</span>{% endif %}
    </label>
    {% if help is not null %}
        <p class="text-xs text-gray-400 mb-2">{{ help }}</p>
    {% endif %}
    <div data-controller="rich-editor"
         {% if error %}aria-invalid="true" tabindex="-1"{% endif %}
         {% if placeholder %}data-rich-editor-placeholder-value="{{ placeholder }}"{% endif %}>
        <div id="{{ id }}" data-rich-editor-target="editor"></div>
        <textarea name="{{ name }}"
                  data-rich-editor-target="input"
                  {% if required %}aria-required="true"{% endif %}
                  class="hidden">{{ value }}</textarea>
    </div>
    {% if error %}
        <p class="mt-1 text-xs text-red-600">{{ error }}</p>
    {% endif %}
</div>
