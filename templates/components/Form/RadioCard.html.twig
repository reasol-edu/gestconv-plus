{% props name, value, label, help = null, checked = false, tone = 'forest', disabled = false %}
{% set cardTone = {
    forest: 'has-[:checked]:border-forest-400 has-[:checked]:bg-forest-50',
    gray:   'has-[:checked]:border-gray-400 has-[:checked]:bg-gray-50',
    red:    'has-[:checked]:border-red-400 has-[:checked]:bg-red-50',
}[tone] %}
{% set inputTone = {
    forest: 'text-forest-600 focus:ring-forest-500',
    gray:   'text-gray-500 focus:ring-gray-400',
    red:    'text-red-600 focus:ring-red-500',
}[tone] %}
<label class="flex {{ help is not null ? 'items-start' : 'items-center' }} gap-3 rounded-xl border border-gray-200 px-4 py-3 transition-colors
              hover:border-gray-300 {{ cardTone }} {{ disabled ? 'opacity-60 cursor-not-allowed' : 'cursor-pointer' }}">
    <input type="radio" name="{{ name }}" value="{{ value }}"
           {% if checked %}checked{% endif %}
           {% if disabled %}disabled{% endif %}
           {{ attributes.without('class') }}
           class="{{ help is not null ? 'mt-0.5 ' : '' }}h-4 w-4 border-gray-300 {{ inputTone }}">
    {% if help is not null %}
        <span>
            <span class="block text-sm font-medium text-gray-700">{{ label }}</span>
            <span class="block text-xs text-gray-500">{{ help }}</span>
        </span>
    {% else %}
        <span class="text-sm font-medium text-gray-700">{{ label }}</span>
    {% endif %}
</label>
