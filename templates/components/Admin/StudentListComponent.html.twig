{% import 'components/_sort_header.html.twig' as sort %}
{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes.defaults(stimulus_controller('filter-persist', {
    centreId: centre.id.toRfc4122,
    active: this.hasActiveFilters,
    key: 'student-filters',
    defaults: {search: '', groupId: '', sort: '', sortDir: 'asc'},
})) }}>
    {% if centre.activeAcademicYear is null %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:exclamation-circle', {class: 'mx-auto h-10 w-10 text-amber-300 mb-3'}) }}
            <p class="text-sm text-gray-500">{{ 'students.no_active_year'|trans({}, 'admin') }}</p>
        </div>
    {% else %}
        {% set can_write = not is_viewing_past_year() %}
        {% set pagination = this.pagination %}

        {# Barra de filtros #}
        <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50 flex flex-wrap items-center gap-3">
            <div class="relative flex-1 min-w-48">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
                </div>
                <input type="search"
                       data-model="norender|search"
                       data-action="input->live#action"
                       data-live-action-param="resetPage"
                       placeholder="{{ 'students.search'|trans({}, 'admin') }}"
                       value="{{ search }}"
                       class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                              text-gray-900 placeholder-gray-400 focus:border-forest-500 focus:outline-none
                              focus:ring-3 focus:ring-forest-500/20 transition-colors">
            </div>

            {% set availableGroups = this.availableGroups %}
            {% set activeGroupIds = availableGroups|map(g => g.id.toRfc4122) %}
            {% if availableGroups is not empty %}
                <select data-model="norender|groupId"
                        data-action="change->live#action"
                        data-live-action-param="resetPage"
                        class="rounded-lg border border-gray-200 bg-white py-2 pl-3 pr-8 text-sm text-gray-700
                               focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20
                               transition-colors shrink-0">
                    <option value="">{{ 'students.filter.all_groups'|trans({}, 'admin') }}</option>
                    {% for group in availableGroups %}
                        <option value="{{ group.id.toRfc4122 }}" {{ groupId == group.id.toRfc4122 ? 'selected' : '' }}>
                            {{ group.name }}
                        </option>
                    {% endfor %}
                </select>
            {% endif %}
<svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
            </svg>
        </div>

        <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
        {% if pagination.totalItems == 0 %}
            <div class="px-6 py-16 text-center">
                {{ ux_icon('heroicons:users', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">
                    {{ (search is not empty or groupId is not empty ? 'students.search_empty' : 'students.empty')|trans({}, 'admin') }}
                </p>
            </div>
        {% else %}
            <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        {{ sort.th('students.col.nie'|trans({}, 'admin'), 'nie', this.sort, this.sortDir) }}
                        {{ sort.th('students.col.name'|trans({}, 'admin'), 'name', this.sort, this.sortDir) }}
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'students.col.groups'|trans({}, 'admin') }}</th>
                        {% if can_write %}<th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'students.col.actions'|trans({}, 'admin') }}</th>{% endif %}
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for student in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'students.col.nie'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 font-mono text-xs text-gray-700 font-medium">{{ student.studentId }}</td>
                            <td data-label="{{ 'students.col.name'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4">
                                {% if can_write %}
                                    <a href="{{ path('app_admin_students_edit', {centreId: centre.id, id: student.id}) }}"
                                       class="font-medium text-gray-900 hover:text-forest-700 transition-colors">{{ student.name.lastName }}, {{ student.name.firstName }}</a>
                                {% else %}
                                    <span class="font-medium text-gray-900">{{ student.name.lastName }}, {{ student.name.firstName }}</span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'students.col.groups'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4">
                                <div class="flex flex-wrap gap-1 sm:justify-start justify-end">
                                    {% for group in student.groups|filter(g => g.id.toRfc4122 in activeGroupIds) %}
                                        <span class="inline-flex items-center rounded-full bg-forest-50 px-2 py-0.5 text-xs font-medium text-forest-700">
                                            {{ group.name }}
                                        </span>
                                    {% else %}
                                        <span class="text-xs text-gray-400">—</span>
                                    {% endfor %}
                                </div>
                            </td>
                            {% if can_write %}
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('app_admin_students_edit', {centreId: centre.id, id: student.id}) }}"
                                       class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium
                                              text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                        {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'students.action.edit'|trans({}, 'admin') }}
                                    </a>
                                    <form method="post"
                                          action="{{ path('app_admin_students_delete', {centreId: centre.id, id: student.id}) }}"
                                          class="js-confirm-form"
                                          data-confirm="{{ 'students.delete_confirm'|trans({}, 'admin')|e('html_attr') }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_student_' ~ student.id) }}">
                                        <button type="submit"
                                                class="js-confirm-trigger inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium
                                                       text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors">
                                            {{ ux_icon('heroicons:trash', {class: 'h-3.5 w-3.5'}) }}
                                            {{ 'students.action.delete'|trans({}, 'admin') }}
                                        </button>
                                    </form>
                                </div>
                            </td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>

            {{ pager.nav(pagination) }}
        {% endif %}
        </div>
    {% endif %}
</div>
