{% import 'components/_pagination_live.html.twig' as pager %}

{% set pagination = this.pagination %}
{% set hasFilters = this.hasActiveFilters %}
{% set selectedTeacher = this.selectedTeacher %}

<div {{ attributes }}>

    {# ── Panel de filtros ──────────────────────────────────────────────────── #}
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 space-y-3">
        <div class="flex flex-wrap items-end gap-3">
            <div class="flex flex-col gap-1 min-w-40">
                <label class="text-xs font-medium text-gray-500">{{ 'absence.list.date_from'|trans({}, 'admin') }}</label>
                <input type="date"
                       data-model="dateFrom"
                       value="{{ dateFrom }}"
                       class="rounded-lg border border-gray-200 bg-white py-1.5 px-3 text-sm text-gray-900
                              focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
            </div>
            <div class="flex flex-col gap-1 min-w-40">
                <label class="text-xs font-medium text-gray-500">{{ 'absence.list.date_to'|trans({}, 'admin') }}</label>
                <input type="date"
                       data-model="dateTo"
                       value="{{ dateTo }}"
                       class="rounded-lg border border-gray-200 bg-white py-1.5 px-3 text-sm text-gray-900
                              focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
            </div>
            <div class="flex flex-wrap gap-1.5 pb-0.5">
                <button type="button" data-action="live#action" data-live-action-param="quickToday"
                        class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-600
                               hover:bg-forest-50 hover:border-forest-200 hover:text-forest-700 transition-colors">
                    {{ 'absence.list.quick_today'|trans({}, 'admin') }}
                </button>
            </div>

            <div class="flex flex-col gap-1 min-w-56 flex-1">
                <label class="text-xs font-medium text-gray-500">{{ 'absence.list.col.teacher'|trans({}, 'admin') }}</label>
                <select data-model="teacherId"
                        data-controller="symfony--ux-autocomplete--autocomplete"
                        data-symfony--ux-autocomplete--autocomplete-url-value="{{ path('ux_entity_autocomplete', {alias: 'teacher_centre', academicYearId: year.id}) }}"
                        data-symfony--ux-autocomplete--autocomplete-min-characters-value="2"
                        data-symfony--ux-autocomplete--autocomplete-no-results-found-text-value="{{ 'autocomplete.no_results'|trans({}, 'admin') }}"
                        data-symfony--ux-autocomplete--autocomplete-placeholder-value="{{ 'absence.list.teacher_placeholder'|trans({}, 'admin') }}"
                        data-symfony--ux-autocomplete--autocomplete-tom-select-options-value='{"dropdownParent":"body"}'
                        class="rounded-lg border border-gray-200 bg-white py-1.5 px-3 text-sm text-gray-900
                               focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors w-full">
                    <option value="">{{ 'absence.list.teacher_all'|trans({}, 'admin') }}</option>
                    {% if selectedTeacher is not null %}
                        <option value="{{ teacherId }}" selected>
                            {{ selectedTeacher.name.lastName }}, {{ selectedTeacher.name.firstName }}
                        </option>
                    {% endif %}
                </select>
            </div>

            <div class="flex items-center gap-2 pb-0.5">
                <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                </svg>
                {% if hasFilters %}
                    <button type="button" data-action="live#action" data-live-action-param="clearFilters"
                            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs
                                   font-medium text-gray-600 hover:bg-gray-100 transition-colors shrink-0">
                        {{ ux_icon('heroicons:x-mark', {class: 'h-3.5 w-3.5'}) }}
                        {{ 'absence.list.clear_filters'|trans({}, 'admin') }}
                    </button>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Tabla ──────────────────────────────────────────────────── #}
    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:user-minus', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm text-gray-500">
                {{ (hasFilters ? 'absence.list.search_empty' : 'absence.empty')|trans({}, 'admin') }}
            </p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'absence.list.col.teacher'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'absence.col.start_date'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'absence.col.end_date'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'absence.col.activities'|trans({}, 'admin') }}</th>
                        <th scope="col" class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for absence in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'absence.list.col.teacher'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-3 text-gray-800 whitespace-nowrap">
                                {{ absence.teacher.name.lastName }}, {{ absence.teacher.name.firstName }}
                            </td>
                            <td data-label="{{ 'absence.col.start_date'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-3 text-gray-700 whitespace-nowrap">
                                {{ absence.startDate|date('d/m/Y') }}
                            </td>
                            <td data-label="{{ 'absence.col.end_date'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-3 text-gray-700 whitespace-nowrap">
                                {{ absence.endDate|date('d/m/Y') }}
                            </td>
                            <td data-label="{{ 'absence.col.activities'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-3 text-gray-700">
                                {{ absence.activities|length }}
                            </td>
                            <td class="px-6 py-3 text-right">
                                <a href="{{ path('app_absences_show', {id: absence.id}) }}"
                                   class="inline-flex items-center rounded-lg p-1.5 text-gray-400 hover:text-forest-600 hover:bg-gray-100 transition-colors"
                                   title="{{ 'absence.view'|trans({}, 'admin') }}">
                                    {{ ux_icon('heroicons:eye', {class: 'h-4 w-4'}) }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {{ pager.nav(pagination) }}
    {% endif %}
    </div>
</div>
