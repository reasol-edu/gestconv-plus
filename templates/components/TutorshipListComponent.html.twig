{% import 'components/_sort_header.html.twig' as sort %}
{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes.defaults(stimulus_controller('filter-persist', {
    centreId: centre.id.toRfc4122,
    active: this.hasActiveFilters,
    key: 'tutorship-filters',
    defaults: {search: '', groupId: '', sort: '', sortDir: 'asc'},
})) }}>
    {% set pagination = this.pagination %}

    {# Barra de filtros #}
    <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50 flex flex-wrap items-center gap-3">
        <div class="relative flex-1 min-w-48">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
            </div>
            <input type="search"
                   data-model="norender|search"
                   data-action="input->live#action"
                   data-live-action-param="resetPage"
                   placeholder="{{ 'tutorship.search'|trans({}, 'admin') }}"
                   value="{{ search }}"
                   class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                          text-gray-900 placeholder-gray-400 focus:border-forest-500 focus:outline-none
                          focus:ring-3 focus:ring-forest-500/20 transition-colors">
        </div>

        {% set availableGroups = this.availableGroups %}
        {% if availableGroups is not empty %}
            <select data-model="norender|groupId"
                    data-action="change->live#action"
                    data-live-action-param="resetPage"
                    class="rounded-lg border border-gray-200 bg-white py-2 pl-3 pr-8 text-sm text-gray-700
                           focus:border-forest-500 focus:outline-none focus:ring-3 focus:ring-forest-500/20
                           transition-colors shrink-0">
                <option value="">{{ 'tutorship.filter.all_groups'|trans({}, 'admin') }}</option>
                {% for group in availableGroups %}
                    <option value="{{ group.id.toRfc4122 }}" {{ groupId == group.id.toRfc4122 ? 'selected' : '' }}>
                        {{ group.name }}
                    </option>
                {% endfor %}
            </select>
        {% endif %}
        <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
        {% if pagination.totalItems == 0 %}
            <div class="px-6 py-16 text-center">
                {{ ux_icon('heroicons:users', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">
                    {{ (search is not empty or groupId is not empty ? 'tutorship.search_empty' : 'tutorship.empty')|trans({}, 'admin') }}
                </p>
            </div>
        {% else %}
            <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        {{ sort.th('tutorship.col.name'|trans({}, 'admin'), 'name', this.sort, this.sortDir) }}
                        {{ sort.th('tutorship.col.group'|trans({}, 'admin'), 'group', this.sort, this.sortDir) }}
                        {{ sort.th('tutorship.col.reports_total'|trans({}, 'admin'), 'reportsTotal', this.sort, this.sortDir, 'right') }}
                        {{ sort.th('tutorship.col.reports_unnotified'|trans({}, 'admin'), 'reportsUnnotified', this.sort, this.sortDir, 'right') }}
                        {{ sort.th('tutorship.col.reports_prescribed'|trans({}, 'admin'), 'reportsPrescribed', this.sort, this.sortDir, 'right') }}
                        {{ sort.th('tutorship.col.sanctions_total'|trans({}, 'admin'), 'sanctionsTotal', this.sort, this.sortDir, 'right') }}
                        {{ sort.th('tutorship.col.sanctions_unnotified'|trans({}, 'admin'), 'sanctionsUnnotified', this.sort, this.sortDir, 'right') }}
                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'tutorship.col.actions'|trans({}, 'admin') }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for row in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'tutorship.col.name'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 font-medium text-gray-900">
                                {{ row.lastName }}, {{ row.firstName }}
                            </td>
                            <td data-label="{{ 'tutorship.col.group'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-gray-700">
                                {{ row.groupName }}
                            </td>
                            <td data-label="{{ 'tutorship.col.reports_total'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-right tabular-nums text-gray-900">
                                {{ row.reportsTotal }}
                                <span class="text-xs text-gray-400">({{ row.reportsTotal - row.reportsSerious }}N / {{ row.reportsSerious }}G)</span>
                            </td>
                            <td data-label="{{ 'tutorship.col.reports_unnotified'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-right tabular-nums {{ row.reportsUnnotified > 0 ? 'text-amber-600 font-medium' : 'text-gray-900' }}">
                                {{ row.reportsUnnotified }}
                            </td>
                            <td data-label="{{ 'tutorship.col.reports_prescribed'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-right tabular-nums text-gray-900">
                                {{ row.reportsPrescribed }}
                            </td>
                            <td data-label="{{ 'tutorship.col.sanctions_total'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-right tabular-nums text-gray-900">
                                {{ row.sanctionsTotal }}
                            </td>
                            <td data-label="{{ 'tutorship.col.sanctions_unnotified'|trans({}, 'admin')|e('html_attr') }}" class="px-6 py-4 text-right tabular-nums {{ row.sanctionsUnnotified > 0 ? 'text-amber-600 font-medium' : 'text-gray-900' }}">
                                {{ row.sanctionsUnnotified }}
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end">
                                    <a href="{{ path('app_students_show', {id: row.studentId}) }}"
                                       class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium
                                              text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                        {{ ux_icon('heroicons:identification', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'tutorship.action.view_profile'|trans({}, 'admin') }}
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>

            <p class="px-6 py-2 text-xs text-gray-500">{{ 'group_stats.legend'|trans({}, 'admin') }}</p>

            {{ pager.nav(pagination) }}
        {% endif %}
    </div>
</div>
