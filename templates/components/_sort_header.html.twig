{#
   Cabecera de columna ordenable para listados Live.
   - label: texto visible
   - column: clave de la allowlist del repositorio (p. ej. 'name')
   - currentSort / currentDir: estado actual del componente
   - align: 'left' (def.) o 'right'
#}
{% macro th(label, column, currentSort, currentDir, align = 'left') %}
    {% set active = currentSort == column %}
    {% set ariaSort = active ? (currentDir == 'desc' ? 'descending' : 'ascending') : 'none' %}
    {% set icon = active ? (currentDir == 'desc' ? 'heroicons:chevron-down' : 'heroicons:chevron-up') : 'heroicons:chevron-up-down' %}
    <th scope="col" aria-sort="{{ ariaSort }}"
        class="px-6 py-3 text-{{ align }} text-xs font-semibold text-gray-500 uppercase tracking-wider">
        <button type="button"
                data-action="live#action"
                data-live-action-param="sortBy"
                data-live-column-param="{{ column }}"
                class="group inline-flex items-center gap-1 uppercase tracking-wider hover:text-gray-700 transition-colors{{ align == 'right' ? ' flex-row-reverse' : '' }}">
            <span>{{ label }}</span>
            {{ ux_icon(icon, {class: 'h-3.5 w-3.5 ' ~ (active ? 'text-forest-600' : 'text-gray-400 group-hover:text-gray-500')}) }}
        </button>
    </th>
{% endmacro %}
