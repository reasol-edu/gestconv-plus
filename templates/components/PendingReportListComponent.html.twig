{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes }}>
    {% set pagination = this.pagination %}

    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
        {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-5 w-5 text-gray-400'}) }}
        <h2 class="text-base font-semibold text-gray-900">{{ 'notification.index.reports_title'|trans({}, 'notifications') }}</h2>
        <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-600 px-2.5 py-0.5 text-xs font-medium">{{ pagination.totalItems }}</span>
        <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-8 text-center">
            <p class="text-sm text-gray-400">{{ 'notification.index.reports_empty'|trans({}, 'notifications') }}</p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <tbody class="divide-y divide-gray-100">
                    {% for report in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'notification.index.col.student'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3 text-gray-800">
                                {{ report.student.name.lastName }}, {{ report.student.name.firstName }}
                            </td>
                            <td data-label="{{ 'notification.index.col.group'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ report.group.name }}</td>
                            <td data-label="{{ 'notification.index.col.date'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ report.occurredAt|date('format.datetime'|trans) }}</td>
                            {% set age = date().diff(date(report.occurredAt)).days %}
                            <td data-label="{{ 'notification.index.col.age'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3 whitespace-nowrap">
                                <span class="text-xs font-medium {{ age >= 7 ? 'text-red-600' : (age >= 3 ? 'text-amber-600' : 'text-gray-400') }}">
                                    {{ 'notification.index.age'|trans({'%count%': age}, 'notifications') }}
                                </span>
                            </td>
                            <td class="px-6 py-3 w-56">
                                <div class="flex items-center justify-end gap-3">
                                    <a href="{{ path('app_incidents_show', {id: report.id}) }}"
                                       class="inline-flex items-center gap-1 rounded-lg border border-gray-200 px-2.5 py-1.5 text-xs font-medium
                                              text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                        {{ ux_icon('heroicons:eye', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'notification.index.view'|trans({}, 'notifications') }}
                                    </a>
                                    {% if is_granted('incident_report.notify', report) and not is_viewing_past_year() %}
                                        <a href="{{ path('app_notifications_register_report', {id: report.id}) }}"
                                           class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                                  hover:bg-forest-700 transition-colors shadow-xs">
                                            {{ ux_icon('heroicons:bell-alert', {class: 'h-3.5 w-3.5'}) }}
                                            {{ 'notification.index.notify'|trans({}, 'notifications') }}
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {{ pager.nav(pagination) }}
    {% endif %}
    </div>
</div>
