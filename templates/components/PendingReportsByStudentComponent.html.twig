{% import 'components/_pagination_live.html.twig' as pager %}
<div {{ attributes }}>
    {% set pagination = this.pagination %}

    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
        {{ ux_icon('heroicons:user-group', {class: 'h-5 w-5 text-gray-400'}) }}
        <h2 class="text-base font-semibold text-gray-900">{{ 'notification.index.students_title'|trans({}, 'notifications') }}</h2>
        <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-600 px-2.5 py-0.5 text-xs font-medium">{{ pagination.totalItems }}</span>
        <svg data-loading class="hidden h-4 w-4 text-forest-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none animate-pulse)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-8 text-center">
            <p class="text-sm text-gray-400">{{ 'notification.index.students_empty'|trans({}, 'notifications') }}</p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="table-cards w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'notification.index.col.student'|trans({}, 'notifications') }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'notification.index.col.pending_count'|trans({}, 'notifications') }}</th>
                        <th scope="col" class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for row in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td data-label="{{ 'notification.index.col.student'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3 text-gray-800 font-medium">
                                {{ row.student.name.lastName }}, {{ row.student.name.firstName }}
                            </td>
                            <td data-label="{{ 'notification.index.col.pending_count'|trans({}, 'notifications')|e('html_attr') }}"
                                class="px-6 py-3">
                                <span class="inline-flex items-center rounded-full bg-amber-100 text-amber-800 px-2.5 py-0.5 text-xs font-semibold">
                                    {{ row.count }}
                                </span>
                            </td>
                            <td class="px-6 py-3 w-56">
                                <div class="flex items-center justify-end">
                                    <a href="{{ path('app_notifications_register_student_reports', {studentId: row.student.id}) }}"
                                       class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                              hover:bg-forest-700 transition-colors shadow-xs">
                                        {{ ux_icon('heroicons:bell-alert', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'notification.index.notify_student'|trans({}, 'notifications') }}
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {{ pager.nav(pagination) }}
    {% endif %}
    </div>
</div>
