{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'notification.title'|trans({}, 'notifications') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-5xl mx-auto space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'notification.title'|trans({}, 'notifications') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'notification.index.help'|trans({}, 'notifications') }}</p>
    </div>

    {# ── Partes pendientes ─────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
            {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-5 w-5 text-gray-400'}) }}
            <h2 class="text-base font-semibold text-gray-900">{{ 'notification.index.reports_title'|trans({}, 'notifications') }}</h2>
            <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-600 px-2.5 py-0.5 text-xs font-medium">{{ reports|length }}</span>
        </div>
        {% if reports is empty %}
            <div class="px-6 py-8 text-center">
                <p class="text-sm text-gray-400">{{ 'notification.index.reports_empty'|trans({}, 'notifications') }}</p>
            </div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <tbody class="divide-y divide-gray-100">
                        {% for report in reports %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-3 text-gray-800">
                                    {{ report.student.name.lastName }}, {{ report.student.name.firstName }}
                                </td>
                                <td class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ report.group.name }}</td>
                                <td class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ report.occurredAt|date('d/m/Y H:i') }}</td>
                                <td class="px-6 py-3 w-56">
                                    <div class="flex items-center justify-end gap-3">
                                        <a href="{{ path('app_incidents_show', {id: report.id}) }}"
                                           class="text-xs font-medium text-gray-500 hover:text-gray-700 transition-colors">
                                            {{ 'notification.index.view'|trans({}, 'notifications') }}
                                        </a>
                                        {% if is_granted('incident_report.notify', report) %}
                                            <a href="{{ path('app_notifications_register_report', {id: report.id}) }}"
                                               class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                                      hover:bg-forest-700 transition-colors shadow-xs">
                                                {{ ux_icon('heroicons:bell-alert', {class: 'h-3.5 w-3.5'}) }}
                                                {{ 'notification.index.notify'|trans({}, 'notifications') }}
                                            </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {# ── Sanciones pendientes ──────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
            {{ ux_icon('heroicons:scale', {class: 'h-5 w-5 text-gray-400'}) }}
            <h2 class="text-base font-semibold text-gray-900">{{ 'notification.index.sanctions_title'|trans({}, 'notifications') }}</h2>
            <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-600 px-2.5 py-0.5 text-xs font-medium">{{ sanctions|length }}</span>
        </div>
        {% if sanctions is empty %}
            <div class="px-6 py-8 text-center">
                <p class="text-sm text-gray-400">{{ 'notification.index.sanctions_empty'|trans({}, 'notifications') }}</p>
            </div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <tbody class="divide-y divide-gray-100">
                        {% for sanction in sanctions %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-3 text-gray-800">
                                    {{ sanction.student.name.lastName }}, {{ sanction.student.name.firstName }}
                                </td>
                                <td class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ sanction.group.name }}</td>
                                <td class="px-6 py-3 text-gray-500 whitespace-nowrap">{{ sanction.createdAt|date('d/m/Y') }}</td>
                                <td class="px-6 py-3 w-56">
                                    <div class="flex items-center justify-end gap-3">
                                        <a href="{{ path('app_sanctions_show', {id: sanction.id}) }}"
                                           class="text-xs font-medium text-gray-500 hover:text-gray-700 transition-colors">
                                            {{ 'notification.index.view'|trans({}, 'notifications') }}
                                        </a>
                                        {% if is_granted('sanction.notify', sanction) %}
                                            <a href="{{ path('app_notifications_register_sanction', {id: sanction.id}) }}"
                                               class="inline-flex items-center gap-1.5 rounded-lg bg-forest-600 px-3 py-1.5 text-xs font-semibold text-white
                                                      hover:bg-forest-700 transition-colors shadow-xs">
                                                {{ ux_icon('heroicons:bell-alert', {class: 'h-3.5 w-3.5'}) }}
                                                {{ 'notification.index.notify'|trans({}, 'notifications') }}
                                            </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
