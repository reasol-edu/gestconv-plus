{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'notification.title'|trans({}, 'notifications') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'notification.title'|trans({}, 'notifications') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'notification.index.help'|trans({}, 'notifications') }}</p>
    </div>

    {# ── Pestañas ─────────────────────────────────────────────────────── #}
    <nav class="flex gap-6 border-b border-gray-200" aria-label="{{ 'notification.tabs.aria'|trans({}, 'notifications') }}">
        <a href="{{ path('app_notifications_index', {tab: 'pending'}) }}"
           {% if tab == 'pending' %}aria-current="page"{% endif %}
           class="-mb-px inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium transition-colors
                  {{ tab == 'pending' ? 'border-forest-600 text-forest-700' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            {{ ux_icon('heroicons:bell-alert', {class: 'h-4 w-4'}) }}
            {{ 'notification.tabs.pending'|trans({}, 'notifications') }}
        </a>
        <a href="{{ path('app_notifications_index', {tab: 'history'}) }}"
           {% if tab == 'history' %}aria-current="page"{% endif %}
           class="-mb-px inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium transition-colors
                  {{ tab == 'history' ? 'border-forest-600 text-forest-700' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            {{ ux_icon('heroicons:clock', {class: 'h-4 w-4'}) }}
            {{ 'notification.tabs.history'|trans({}, 'notifications') }}
        </a>
    </nav>

    {% if tab == 'pending' %}
    {# ── Estudiantes con partes pendientes de notificar ────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:PendingReportsByStudentComponent :centre="centre" />
    </div>

    {# ── Partes pendientes ─────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:PendingReportListComponent :centre="centre" />
    </div>

    {# ── Sanciones pendientes ──────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:PendingSanctionListComponent :centre="centre" />
    </div>
    {% else %}
    {# ── Historial de notificaciones ──────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:CommunicationHistoryListComponent :centre="centre" />
    </div>
    {% endif %}

</div>
{% endblock %}
