{# Expects: action_url, target_id, methods #}
<div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4">{{ 'notification.form.title'|trans({}, 'notifications') }}</h2>

    <form method="post" action="{{ action_url }}" class="space-y-5">
        <input type="hidden" name="_token" value="{{ csrf_token('register_communication_' ~ target_id) }}">

        <div>
            <label for="method_id" class="block text-sm font-medium text-gray-700 mb-1.5">{{ 'notification.form.field.method'|trans({}, 'notifications') }}</label>
            <select id="method_id" name="method_id" required
                    class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                           focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                <option value="">{{ 'notification.form.field.method_placeholder'|trans({}, 'notifications') }}</option>
                {% for method in methods %}
                    <option value="{{ method.id }}">{{ method.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label for="performed_at" class="block text-sm font-medium text-gray-700 mb-1.5">{{ 'notification.form.field.performed_at'|trans({}, 'notifications') }}</label>
            <input type="datetime-local" id="performed_at" name="performed_at" required
                   value="{{ 'now'|date('Y-m-d\\TH:i') }}"
                   class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                          focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
        </div>

        <div>
            <p class="block text-sm font-medium text-gray-700 mb-2">{{ 'notification.form.field.result'|trans({}, 'notifications') }}</p>
            <div class="grid grid-cols-2 gap-3">
                <label class="flex items-start gap-3 cursor-pointer rounded-xl border-2 px-4 py-3.5 transition-all
                              border-gray-200 bg-white hover:border-gray-300
                              has-[:checked]:border-forest-500 has-[:checked]:bg-forest-50">
                    <input type="radio" name="result" value="notified" checked
                           class="mt-0.5 h-4 w-4 shrink-0 border-gray-300 text-forest-600 focus:ring-forest-500">
                    <div>
                        <span class="block text-sm font-semibold text-gray-900">{{ 'notification.result.notified'|trans({}, 'notifications') }}</span>
                        <p class="text-xs text-gray-500 mt-0.5">{{ 'notification.form.field.result_notified_help'|trans({}, 'notifications') }}</p>
                    </div>
                </label>
                <label class="flex items-start gap-3 cursor-pointer rounded-xl border-2 px-4 py-3.5 transition-all
                              border-gray-200 bg-white hover:border-gray-300
                              has-[:checked]:border-red-400 has-[:checked]:bg-red-50">
                    <input type="radio" name="result" value="not_notified"
                           class="mt-0.5 h-4 w-4 shrink-0 border-gray-300 text-red-500 focus:ring-red-400">
                    <div>
                        <span class="block text-sm font-semibold text-gray-900">{{ 'notification.result.not_notified'|trans({}, 'notifications') }}</span>
                        <p class="text-xs text-gray-500 mt-0.5">{{ 'notification.form.field.result_not_notified_help'|trans({}, 'notifications') }}</p>
                    </div>
                </label>
            </div>
        </div>

        <div>
            <label for="description" class="block text-sm font-medium text-gray-700 mb-1.5">{{ 'notification.form.field.description'|trans({}, 'notifications') }}</label>
            <textarea id="description" name="description" rows="3"
                      class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                             focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors"></textarea>
        </div>

        <div class="flex items-center justify-end gap-3 pt-2">
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-forest-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                {{ 'notification.form.submit'|trans({}, 'notifications') }}
            </button>
        </div>
    </form>
</div>
