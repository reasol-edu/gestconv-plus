{# Expects: action_url, target_id, methods #}
<div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4">{{ 'notification.form.title'|trans({}, 'notifications') }}</h2>

    <form method="post" action="{{ action_url }}" class="space-y-5">
        <input type="hidden" name="_token" value="{{ csrf_token('register_communication_' ~ target_id) }}">

        {% include 'notification/_communication_form_fields.html.twig' with { methods: methods } %}

        <div class="flex items-center justify-end gap-3 pt-2">
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-forest-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                {{ 'notification.form.submit'|trans({}, 'notifications') }}
            </button>
        </div>
    </form>
</div>
