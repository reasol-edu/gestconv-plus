{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'notification.register_report.title'|trans({}, 'notifications') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_notifications_index') }}" class="hover:text-forest-600 transition-colors">{{ 'notification.title'|trans({}, 'notifications') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'notification.register_report.title'|trans({}, 'notifications') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">
            {{ report.student.name.lastName }}, {{ report.student.name.firstName }}
        </h1>
        <p class="mt-1 text-sm text-gray-500">
            {{ 'notification.register_report.report_ref'|trans({'%number%': report.number}, 'notifications') }}
            · {{ report.group.name }} · {{ report.occurredAt|date('d/m/Y H:i') }}
            · {{ report.registeredBy.name.lastName }}, {{ report.registeredBy.name.firstName }}
        </p>
        <p class="mt-2">
            <a href="{{ path('app_incidents_show', {id: report.id}) }}" class="text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors">
                {{ 'notification.register_report.view_report'|trans({}, 'notifications') }}
            </a>
        </p>
    </div>

    {% if report.isNotified %}
        <div class="rounded-xl px-4 py-3 text-sm font-medium bg-green-50 text-green-800 border border-green-200 flex items-center gap-2">
            {{ ux_icon('heroicons:check-circle', {class: 'h-4 w-4 shrink-0'}) }}
            {{ 'notification.register_report.already_notified'|trans({}, 'notifications') }}
        </div>
    {% endif %}

    {% include 'student/_contact.html.twig' with { student: report.student, canSeeContact: canSeeContact } %}

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs divide-y divide-gray-100">
        {% include 'notification/_report_detail.html.twig' with { report: report } %}
    </div>

    {% if observations is not empty %}
        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-3">{{ 'incident.observation.title'|trans({}, 'admin') }}</h2>
            {% include 'incident/_observation_list.html.twig' with { observations: observations } %}
        </div>
    {% endif %}

    {% if methods is empty %}
        <div class="rounded-xl px-4 py-3 text-sm font-medium bg-amber-50 text-amber-800 border border-amber-200">
            {{ 'notification.form.no_methods'|trans({}, 'notifications') }}
        </div>
    {% else %}
        {% include 'notification/_communication_form.html.twig' with {
            action_url: path('app_notifications_register_report', {id: report.id}),
            target_id: report.id,
            methods: methods,
        } %}
    {% endif %}

    <div>
        <h2 class="text-base font-semibold text-gray-900 mb-3">{{ 'notification.history.title'|trans({}, 'notifications') }}</h2>
        {% include 'notification/_communication_history.html.twig' with { history: history } %}
    </div>

</div>
{% endblock %}
