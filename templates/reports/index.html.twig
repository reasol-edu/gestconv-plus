{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'reports'|trans({}, 'navigation') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'reports'|trans({}, 'navigation') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'reports'|trans({}, 'navigation') }}</h1>
        {% if centre.activeAcademicYear %}
            <p class="mt-1 text-sm text-gray-500">{{ centre.activeAcademicYear.name }}</p>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">

        {# ── Estadísticas por grupo ── #}
        <a href="{{ centre.activeAcademicYear ? path('app_reports_group_stats', {centreId: centre.id}) : '#' }}"
           class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                  hover:border-forest-200 hover:shadow-sm transition-all
                  {{ centre.activeAcademicYear is null ? 'opacity-60 pointer-events-none' : '' }}">
            <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                            group-hover:bg-forest-600 group-hover:text-white transition-colors">
                    {{ ux_icon('heroicons:chart-bar', {class: 'h-5 w-5'}) }}
                </div>
                <h2 class="text-base font-semibold text-gray-900">{{ 'group_stats.title'|trans({}, 'admin') }}</h2>
            </div>
            <div class="px-6 py-4 flex-1">
                <p class="text-sm text-gray-500">{{ 'group_stats.hub_help'|trans({}, 'admin') }}</p>
            </div>
            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                {% if centre.activeAcademicYear %}
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'group_stats.generate'|trans({}, 'admin') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                {% else %}
                    <span class="text-xs text-gray-400">{{ 'group_stats.no_active_year'|trans({}, 'admin') }}</span>
                {% endif %}
            </div>
        </a>

    </div>

</div>
{% endblock %}
