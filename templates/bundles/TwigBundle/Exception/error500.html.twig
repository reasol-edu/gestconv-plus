<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error del servidor · Nexo FP</title>
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
    <link rel="shortcut icon" href="/static/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --forest-300: #85bda6;
            --forest-400: #5fa07f;
            --forest-500: #3e885b;
            --forest-600: #357750;
            --forest-700: #2c6343;
            --forest-800: #245035;
            --forest-900: #1d3d28;
            --forest-950: #2f4b26;
            --red-400:   #f87171;
            --amber-400: #fbbf24;
        }

        html, body { height: 100%; }

        body {
            font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
            background: var(--forest-950);
            color: white;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Anillos y rombos con parallax ───────────────────────────────── */
        .orb {
            position: fixed;
            border-radius: 50%;
            background: transparent;
            pointer-events: none;
            will-change: transform;
        }
        .orb-a { width: 540px; height: 540px; top: -180px; right: -180px; border: 3px solid rgba(255,255,255,0.18); }
        .orb-b { width: 360px; height: 360px; top: -100px; right: -100px; border: 3px solid rgba(255,255,255,0.10); }
        .orb-c { width: 300px; height: 300px; top: 38%;    right: -80px;  border: 3px solid rgba(95,160,127,0.38); background: rgba(62,136,91,0.07); }
        .orb-d { width: 460px; height: 460px; bottom: -130px; left: -130px; border: 3px solid rgba(255,255,255,0.15); }
        .orb-e { width: 200px; height: 200px; bottom: 20%; left: -40px;   border: 3px solid rgba(133,189,166,0.30); }

        .diamond {
            position: fixed;
            pointer-events: none;
            will-change: transform;
        }
        /* Grupo inferior-derecha (3, algo solapados) */
        .diamond-a { width: 64px; height: 64px; bottom: 13%; right: 7%;  background: rgba(62,136,91,0.13);   transform: rotate(45deg); }
        .diamond-b { width: 44px; height: 44px; bottom: 16%; right: 11%; background: rgba(255,255,255,0.07); transform: rotate(45deg); }
        .diamond-c { width: 30px; height: 30px; bottom: 10%; right: 9%;  background: rgba(133,189,166,0.11); transform: rotate(45deg); }
        /* Grupo superior-izquierda (2, algo solapados) */
        .diamond-d { width: 48px; height: 48px; top: 10%; left: 6%;  background: rgba(255,255,255,0.06); transform: rotate(45deg); }
        .diamond-e { width: 32px; height: 32px; top: 13%; left: 9%;  background: rgba(62,136,91,0.11);   transform: rotate(45deg); }
        /* Aislados */
        .diamond-f { width: 22px; height: 22px; top: 54%; right: 6%; background: rgba(133,189,166,0.10); transform: rotate(45deg); }
        .diamond-g { width: 16px; height: 16px; top: 30%; left: 44%; background: rgba(255,255,255,0.05); transform: rotate(45deg); }

        /* ── Content ──────────────────────────────────────────────────────── */
        .page {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 2rem 1.5rem;
        }

        /* ── Glitching logo ───────────────────────────────────────────────── */
        .glitch-wrap {
            position: relative;
            width: 96px;
            height: 96px;
            margin-bottom: 0.5rem;
        }

        .glitch-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            position: relative;
            z-index: 2;
            animation: glitch-main 7s ease-in-out infinite;
            filter: drop-shadow(0 0 18px rgba(62,136,91,0.3));
        }

        /* Cyan ghost layer */
        .glitch-wrap::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/static/logo.svg') center/contain no-repeat;
            z-index: 1;
            opacity: 0;
            animation: glitch-cyan 7s ease-in-out infinite;
            filter: hue-rotate(160deg) saturate(3) brightness(1.8);
            mix-blend-mode: screen;
        }

        /* Red ghost layer */
        .glitch-wrap::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/static/logo.svg') center/contain no-repeat;
            z-index: 1;
            opacity: 0;
            animation: glitch-red 7s ease-in-out infinite;
            filter: hue-rotate(320deg) saturate(3) brightness(1.8);
            mix-blend-mode: screen;
        }

        @keyframes glitch-main {
            0%, 78%, 100% { transform: none;                clip-path: none;                                       }
            79%           { transform: translate(-4px,  1px); clip-path: polygon(0 15%, 100% 15%, 100% 40%, 0 40%); }
            80%           { transform: translate( 4px, -1px); clip-path: polygon(0 55%, 100% 55%, 100% 78%, 0 78%); }
            81%           { transform: translate(-2px,  2px); clip-path: none;                                       }
            82%           { transform: none;                clip-path: polygon(0 0,  100% 0, 100% 30%, 0 30%);     }
            83%           { transform: translate( 3px, -2px); clip-path: none;                                       }
            84%           { transform: none; }
        }

        @keyframes glitch-cyan {
            0%, 78%, 100% { opacity: 0; transform: none; }
            79%           { opacity: 0.6; transform: translate( 5px, 0); clip-path: polygon(0 15%, 100% 15%, 100% 40%, 0 40%); }
            80%           { opacity: 0.5; transform: translate(-3px, 0); clip-path: polygon(0 58%, 100% 58%, 100% 76%, 0 76%); }
            81%           { opacity: 0; }
            82%           { opacity: 0.4; transform: translate( 4px, 0); clip-path: polygon(0 0, 100% 0, 100% 28%, 0 28%); }
            83%           { opacity: 0; }
        }

        @keyframes glitch-red {
            0%, 78%, 100% { opacity: 0; transform: none; }
            79%           { opacity: 0.6; transform: translate(-5px, 0); clip-path: polygon(0 15%, 100% 15%, 100% 40%, 0 40%); }
            80%           { opacity: 0.5; transform: translate( 3px, 0); clip-path: polygon(0 55%, 100% 55%, 100% 80%, 0 80%); }
            81%           { opacity: 0; }
            82%           { opacity: 0.4; transform: translate(-4px, 0); clip-path: polygon(0 0, 100% 0, 100% 30%, 0 30%); }
            83%           { opacity: 0; }
        }

        /* ── Error code badge ─────────────────────────────────────────────── */
        .code-badge {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: #f87171;
            text-transform: uppercase;
            margin-bottom: 0.25rem;
        }

        /* ── Typography ───────────────────────────────────────────────────── */
        .title {
            margin-top: 1.75rem;
            font-size: clamp(1.2rem, 3vw, 1.6rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            color: white;
        }

        .subtitle {
            margin-top: 0.625rem;
            font-size: 1rem;
            line-height: 1.65;
            color: var(--forest-400);
            max-width: 26rem;
        }

        /* ── Actions ──────────────────────────────────────────────────────── */
        .actions {
            margin-top: 2.5rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: center;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--forest-600);
            color: white;
            font-family: inherit;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: background 0.15s, transform 0.15s, box-shadow 0.2s;
        }
        .btn-primary:hover {
            background: var(--forest-700);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(53,119,80,0.4);
        }
        .btn-primary:active { transform: translateY(0); }

        .btn-ghost {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: transparent;
            color: var(--forest-400);
            font-family: inherit;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            border: 1px solid var(--forest-800);
            text-decoration: none;
            cursor: pointer;
            transition: color 0.15s, border-color 0.15s, transform 0.15s;
        }
        .btn-ghost:hover {
            color: var(--forest-300);
            border-color: var(--forest-600);
            transform: translateY(-1px);
        }

        @media (prefers-reduced-motion: reduce) {
            .glitch-wrap img,
            .glitch-wrap::before,
            .glitch-wrap::after { animation: none; }
            .btn-primary:hover, .btn-ghost:hover { transform: none; }
        }
    </style>
</head>
<body>
    <div class="orb orb-a" data-speed="28"></div>
    <div class="orb orb-b" data-speed="18"></div>
    <div class="orb orb-c" data-speed="50"></div>
    <div class="orb orb-d" data-speed="34"></div>
    <div class="orb orb-e" data-speed="62"></div>
    <div class="diamond diamond-a" data-speed="42"></div>
    <div class="diamond diamond-b" data-speed="56"></div>
    <div class="diamond diamond-c" data-speed="70"></div>

    <main class="page">
        <div class="glitch-wrap" aria-hidden="true">
            <img src="/static/logo.svg" alt="">
        </div>

        <p class="code-badge">Error 500</p>
        <h1 class="title">Algo salió mal</h1>
        <p class="subtitle">Se ha producido un error en el servidor. Si el problema persiste, contacta con el administrador.</p>

        <div class="actions">
            <button type="button" onclick="location.reload()" class="btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                </svg>
                Intentar de nuevo
            </button>
            <a href="/" class="btn-ghost">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                </svg>
                Ir al inicio
            </a>
        </div>
    </main>

    <script>
    (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var els = document.querySelectorAll('[data-speed]');
        var tx = 0, ty = 0, cx = 0, cy = 0;
        document.addEventListener('mousemove', function (e) {
            tx = e.clientX / window.innerWidth  - 0.5;
            ty = e.clientY / window.innerHeight - 0.5;
        });
        (function tick() {
            cx += (tx - cx) * 0.06;
            cy += (ty - cy) * 0.06;
            els.forEach(function (o) {
                var s = +o.dataset.speed;
                o.style.transform = 'translate(' + (cx*s).toFixed(1) + 'px,' + (cy*s).toFixed(1) + 'px)';
            });
            requestAnimationFrame(tick);
        }());
    }());
    </script>
</body>
</html>
