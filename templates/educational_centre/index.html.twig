{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'educational_centre'|trans({}, 'navigation') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">{{ centre.name }}</h1>
        {% if centre.activeAcademicYear %}
            <p class="mt-1 text-sm text-gray-500">{{ centre.activeAcademicYear.name }}</p>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">

        {# ── Docentes del curso ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ centre.activeAcademicYear ? path('app_admin_centre_teachers_index', {centreId: centre.id}) : '#' }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all
                      {{ centre.activeAcademicYear is null ? 'opacity-60 pointer-events-none' : '' }}">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:user-group', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'centre_teachers.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'centre_teachers.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    {% if centre.activeAcademicYear %}
                        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                            {{ 'centre_teachers.manage'|trans({}, 'admin') }}
                            {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                        </span>
                    {% else %}
                        <span class="text-xs text-gray-400">{{ 'centre_teachers.no_active_year'|trans({}, 'admin') }}</span>
                    {% endif %}
                </div>
            </a>
        {% endif %}

        {# ── Oferta formativa ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ centre.activeAcademicYear ? path('app_admin_offer_index', {centreId: centre.id}) : '#' }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all
                      {{ centre.activeAcademicYear is null ? 'opacity-60 pointer-events-none' : '' }}">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:academic-cap', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'offer.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'offer.centre_link_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    {% if centre.activeAcademicYear %}
                        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                            {{ 'offer.manage'|trans({}, 'admin') }}
                            {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                        </span>
                    {% else %}
                        <span class="text-xs text-gray-400">{{ 'offer.no_active_year'|trans({}, 'admin') }}</span>
                    {% endif %}
                </div>
            </a>
        {% endif %}

        {# ── Estudiantes ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ centre.activeAcademicYear ? path('app_admin_students_index', {centreId: centre.id}) : '#' }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all
                      {{ centre.activeAcademicYear is null ? 'opacity-60 pointer-events-none' : '' }}">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:users', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'students.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'students.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    {% if centre.activeAcademicYear %}
                        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                            {{ 'students.manage'|trans({}, 'admin') }}
                            {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                        </span>
                    {% else %}
                        <span class="text-xs text-gray-400">{{ 'students.no_active_year'|trans({}, 'admin') }}</span>
                    {% endif %}
                </div>
            </a>
        {% endif %}

        {# ── Conductas contrarias ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_admin_incident_behaviors_index', {centreId: centre.id}) }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:no-symbol', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'behavior.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'behavior.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'behavior.manage'|trans({}, 'admin') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                </div>
            </a>
        {% endif %}

        {# ── Medidas disciplinarias ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_admin_sanction_measures_index', {centreId: centre.id}) }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:rectangle-stack', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'sanction_measure.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'sanction_measure.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'sanction_measure.manage'|trans({}, 'admin') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                </div>
            </a>
        {% endif %}

        {# ── Métodos de comunicación ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_admin_communication_methods_index', {centreId: centre.id}) }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:chat-bubble-left-right', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'communication_method.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'communication_method.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'communication_method.manage'|trans({}, 'admin') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                </div>
            </a>
        {% endif %}

        {# ── Perfiles ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_admin_centre_profiles_index', {centreId: centre.id}) }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:user-circle', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'centre_profiles.title'|trans({}, 'admin') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'centre_profiles.hub_help'|trans({}, 'admin') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'centre_profiles.manage'|trans({}, 'admin') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                </div>
            </a>
        {% endif %}

        {# ── Ajustes del centro ── equipo directivo y admins #}
        {% if is_granted('educational_centre.section', centre) %}
            <a href="{{ path('app_educational_centre_settings', {centreId: centre.id}) }}"
               class="group rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden flex flex-col
                      hover:border-forest-200 hover:shadow-sm transition-all">
                <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-forest-100 text-forest-600
                                group-hover:bg-forest-600 group-hover:text-white transition-colors">
                        {{ ux_icon('heroicons:adjustments-horizontal', {class: 'h-5 w-5'}) }}
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">{{ 'settings.centre.title'|trans({}, 'settings') }}</h2>
                </div>
                <div class="px-6 py-4 flex-1">
                    <p class="text-sm text-gray-500">{{ 'settings.hub.help'|trans({}, 'settings') }}</p>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-600 group-hover:text-forest-800 transition-colors">
                        {{ 'settings.hub.manage'|trans({}, 'settings') }}
                        {{ ux_icon('heroicons:arrow-right', {class: 'h-4 w-4'}) }}
                    </span>
                </div>
            </a>
        {% endif %}

    </div>

</div>
{% endblock %}
