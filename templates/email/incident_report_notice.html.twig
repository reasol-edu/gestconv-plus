{% extends 'email/_layout.html.twig' %}

{% block content %}
<p style="margin: 0 0 16px;">
    {{ 'emails.greeting'|trans({'%name%': teacher.name.firstName}, 'emails') }}
</p>
<p style="margin: 0 0 24px;">
    {{ (transPrefix ~ '.intro')|trans(params, 'emails') }}
</p>
<p style="margin: 0 0 24px; padding: 12px 16px; background-color: #f9fafb; border-left: 3px solid #677dae; color: #374151; font-size: 13px;">
    {{ report.description }}
</p>
{% if reportUrl is not null %}
<p style="margin: 0 0 24px; text-align: center;">
    <a href="{{ reportUrl }}"
       style="display: inline-block; background-color: #677dae; color: #ffffff; font-size: 14px;
              font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none;">
        {{ 'emails.view_report'|trans({}, 'emails') }}
    </a>
</p>
{% endif %}
{% endblock %}
