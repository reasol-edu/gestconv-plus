{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'calendar') }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold text-gray-900">{{ 'page_title'|trans({}, 'calendar') }}</h1>

    {% if isAdmin %}
    {# ── Pestañas ─────────────────────────────────────────────────────── #}
    <nav class="flex gap-6 border-b border-gray-200" aria-label="{{ 'tabs.aria'|trans({}, 'calendar') }}">
        <a href="{{ path('app_calendar', {tab: 'sanctions'}) }}"
           {% if tab == 'sanctions' %}aria-current="page"{% endif %}
           class="-mb-px inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium transition-colors
                  {{ tab == 'sanctions' ? 'border-forest-600 text-forest-700' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-4 w-4'}) }}
            {{ 'tabs.sanctions'|trans({}, 'calendar') }}
        </a>
        <a href="{{ path('app_calendar', {tab: 'absences'}) }}"
           {% if tab == 'absences' %}aria-current="page"{% endif %}
           class="-mb-px inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium transition-colors
                  {{ tab == 'absences' ? 'border-forest-600 text-forest-700' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            {{ ux_icon('heroicons:user-circle', {class: 'h-4 w-4'}) }}
            {{ 'tabs.absences'|trans({}, 'calendar') }}
        </a>
    </nav>
    {% endif %}

    {% if tab == 'absences' and isAdmin %}
        <twig:AbsenceCalendarComponent />
    {% else %}
        <twig:CalendarComponent />
    {% endif %}

</div>
{% endblock %}
