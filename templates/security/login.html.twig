{% extends 'base.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'login') }}{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Panel izquierdo: marca ─────────────────────────────────────────────── #}
    <div class="hidden lg:flex lg:w-5/12 xl:w-2/5 relative overflow-hidden flex-col
                bg-gradient-to-br from-forest-950 via-forest-900 to-forest-800">

        {# Anillos decorativos #}
        <div class="absolute -top-52 -right-52 w-[40rem] h-[40rem] rounded-full border-[3px] border-white/20"></div>
        <div class="absolute -top-28 -right-28 w-[26rem] h-[26rem] rounded-full border-[3px] border-white/12"></div>
        <div class="absolute top-1/2 -translate-y-1/2 -right-32 w-64 h-64 rounded-full border-[3px] border-forest-400/40 bg-forest-500/10"></div>
        <div class="absolute -bottom-44 -left-44 w-[34rem] h-[34rem] rounded-full border-[3px] border-white/18"></div>
        <div class="absolute bottom-1/3 -left-10 w-40 h-40 rounded-full border-[3px] border-forest-300/35"></div>
        {# Rombos: grupo superior-derecha (3 solapados) #}
        <div class="absolute top-14 right-14 w-20 h-20 rotate-45 bg-white/[0.06]"></div>
        <div class="absolute top-24 right-24 w-12 h-12 rotate-45 bg-forest-400/[0.10]"></div>
        <div class="absolute top-10 right-24 w-9  h-9  rotate-45 bg-white/[0.05]"></div>
        {# Rombos: grupo inferior-derecha (2 solapados) #}
        <div class="absolute bottom-12 right-10 w-16 h-16 rotate-45 bg-forest-400/[0.11]"></div>
        <div class="absolute bottom-20 right-20 w-10 h-10 rotate-45 bg-white/[0.07]"></div>
        {# Rombos: aislados #}
        <div class="absolute top-1/2 -translate-y-1/2 left-8 w-7 h-7 rotate-45 bg-forest-300/[0.09]"></div>
        <div class="absolute bottom-1/3 left-14 w-5 h-5 rotate-45 bg-white/[0.05]"></div>

        <div class="relative flex flex-col justify-between h-full p-12 z-10">
            {# Logo #}
            <div class="flex items-start gap-4">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-40 h-40 shrink-0">
                <span class="text-white/60 text-xs font-medium tracking-tight mt-1">{% if app_version %}v{{ app_version }}{% endif %}</span>
            </div>

            {# Texto central #}
            <div>
                <p class="text-forest-300 text-sm font-medium uppercase tracking-widest mb-4">{{ 'platform_label'|trans({}, 'login') }}</p>
                <h1 class="text-4xl font-bold text-white leading-tight mb-4">
                    {{ app_name }}
                </h1>
                <p class="text-forest-300 text-lg leading-relaxed">
                    {{ 'hero_description'|trans({}, 'login') }}
                </p>
            </div>

            {# Footer #}
            <p class="text-forest-500 text-sm">{{ 'copyright'|trans({'%year%': 'now'|date('Y')}, 'login') }} REASOL, Luis Ramón López López</p>
        </div>
    </div>

    {# ── Panel derecho: formulario ──────────────────────────────────────────── #}
    <div class="flex-1 flex items-center justify-center p-8 bg-white">
        <div class="w-full max-w-md">

            {# Logo #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-14 h-14 shrink-0">
                <span class="text-forest-900 text-lg font-semibold">{{ app_name }}</span>
            </div>

            {# Encabezado #}
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ 'welcome_title'|trans({}, 'login') }}</h2>
                <p class="text-gray-500">{{ 'welcome_subtitle'|trans({}, 'login') }}</p>
            </div>

            {# Contraseña restablecida con éxito #}
            {% if app.request.query.get('password_reset') == 'success' %}
                <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 mb-6 text-sm">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                    </svg>
                    <span>{{ 'password_reset_success'|trans({}, 'login') }}</span>
                </div>
            {% endif %}

            {# Error #}
            {% if error %}
                <div class="flex items-start gap-3 bg-red-50 border border-red-100 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                    </svg>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {# Formulario #}
            <form method="post" novalidate class="space-y-5">

                {# Usuario #}
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'username_label'|trans({}, 'login') }}
                    </label>
                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                            <svg class="w-4.5 h-4.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                            </svg>
                        </div>
                        <input id="username"
                               type="text"
                               name="_username"
                               value="{{ last_username }}"
                               autocomplete="username"
                               {% if last_username is empty %}autofocus{% endif %}
                               required
                               class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-4
                                      text-gray-900 placeholder-gray-400 text-sm
                                      transition-all duration-150
                                      focus:border-forest-500 focus:bg-white focus:ring-3 focus:ring-forest-500/20 focus:outline-none">
                    </div>
                </div>

                {# Contraseña con toggle #}
                {# El enlace «¿Olvidaste tu contraseña?» va en el DOM tras el input
                   (recolocado arriba a la derecha con CSS) para que el tabulador
                   pase del usuario directamente a la contraseña sin perder el foco. #}
                <div data-controller="password-visibility" class="relative">
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'password_label'|trans({}, 'login') }}
                    </label>
                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                            <svg class="w-4.5 h-4.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
                            </svg>
                        </div>
                        <input id="password"
                               type="password"
                               name="_password"
                               autocomplete="current-password"
                               required
                               {% if last_username is not empty %}autofocus{% endif %}
                               data-password-visibility-target="input"
                               class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-11
                                      text-gray-900 placeholder-gray-400 text-sm
                                      transition-all duration-150
                                      focus:border-forest-500 focus:bg-white focus:ring-3 focus:ring-forest-500/20 focus:outline-none">
                        <button type="button"
                                data-action="password-visibility#toggle"
                                aria-label="{{ 'password_visibility.toggle'|trans({}, 'login') }}"
                                aria-pressed="false"
                                aria-controls="password"
                                class="absolute inset-y-0 right-0 flex items-center pr-3.5 text-gray-400 hover:text-gray-600 transition-colors">
                            {# Ojo abierto (contraseña oculta) #}
                            <svg data-password-visibility-target="eyeOpen"
                                 class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                            </svg>
                            {# Ojo tachado (contraseña visible) #}
                            <svg data-password-visibility-target="eyeClosed"
                                 class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                            </svg>
                        </button>
                    </div>
                    <a href="{{ path('app_password_reset_request') }}"
                       class="absolute top-0 right-0 text-xs text-forest-600 hover:text-forest-800 transition-colors">
                        {{ 'forgot_password'|trans({}, 'login') }}
                    </a>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Botón #}
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-forest-600 hover:bg-forest-700 active:bg-forest-800
                               text-white font-semibold text-sm
                               py-3 px-4 rounded-xl
                               transition-colors duration-150
                               focus:outline-none focus:ring-3 focus:ring-forest-500/40">
                    {{ 'submit'|trans({}, 'login') }}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                    </svg>
                </button>
            </form>
        </div>
    </div>

</div>
{% endblock %}
