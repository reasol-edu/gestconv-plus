{% extends 'base.html.twig' %}

{% block title %}{{ 'force_password_change.title'|trans({}, 'messages') }} · {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Panel izquierdo: marca ─────────────────────────────────────────────── #}
    <div class="hidden lg:flex lg:w-5/12 xl:w-2/5 relative overflow-hidden flex-col
                bg-gradient-to-br from-forest-950 via-forest-900 to-forest-800">
        <div class="absolute -top-32 -right-32 w-[28rem] h-[28rem] rounded-full bg-white/5"></div>
        <div class="absolute top-1/2 -right-16 w-64 h-64 rounded-full bg-forest-600/30"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-white/5"></div>
        <div class="absolute bottom-1/3 right-8 w-32 h-32 rounded-full bg-forest-500/20"></div>
        <div class="relative flex flex-col justify-between h-full p-12 z-10">
            <div class="flex items-start gap-4">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-40 h-40 shrink-0">
                <span class="text-white/60 text-xs font-medium tracking-tight mt-1">{% if app_version %}v{{ app_version }}{% endif %}</span>
            </div>
            <div>
                <p class="text-forest-300 text-sm font-medium uppercase tracking-widest mb-4">{{ 'platform_label'|trans({}, 'login') }}</p>
                <h1 class="text-4xl font-bold text-white leading-tight mb-4">{{ app_name }}</h1>
                <p class="text-forest-300 text-lg leading-relaxed">{{ 'force_password_change.hero'|trans({}, 'messages') }}</p>
            </div>
            <p class="text-forest-500 text-sm">{{ 'copyright'|trans({'%year%': 'now'|date('Y')}, 'login') }} REASOL, Luis Ramón López López</p>
        </div>
    </div>

    {# ── Panel derecho: formulario ──────────────────────────────────────────── #}
    <div class="flex-1 flex items-center justify-center p-8 bg-white">
        <div class="w-full max-w-md">

            {# Logo móvil #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-14 h-14 shrink-0">
                <span class="text-forest-900 text-lg font-semibold">{{ app_name }}</span>
            </div>

            {# Encabezado #}
            <div class="mb-8 flex items-start gap-3">
                <div class="shrink-0 rounded-xl bg-amber-100 p-2.5">
                    {{ ux_icon('heroicons:shield-exclamation', {class: 'h-5 w-5 text-amber-600'}) }}
                </div>
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ 'force_password_change.title'|trans({}, 'messages') }}</h2>
                    <p class="text-gray-500 text-sm">{{ 'force_password_change.intro'|trans({}, 'messages') }}</p>
                </div>
            </div>

            {# Error general #}
            {% if errors.general is defined %}
                <div class="flex items-start gap-3 bg-red-50 border border-red-100 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                    </svg>
                    <span>{{ errors.general }}</span>
                </div>
            {% endif %}

            {# Formulario #}
            <form method="post" novalidate class="space-y-5">

                {# Contraseña actual #}
                <div data-controller="password-visibility">
                    <label for="current_password" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'profile.field.current_password'|trans({}, 'messages') }}
                    </label>
                    <div class="relative">
                        <input id="current_password" type="password" name="current_password"
                               autocomplete="current-password" autofocus required
                               data-password-visibility-target="input"
                               class="block w-full rounded-xl border py-3 px-3.5 pr-11 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.current_password is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-forest-500 focus:bg-white focus:ring-forest-500/20' }}">
                        <button type="button" data-action="password-visibility#toggle"
                                aria-label="{{ 'password_visibility.toggle'|trans({}, 'login') }}"
                                aria-pressed="false"
                                aria-controls="current_password"
                                class="absolute inset-y-0 right-0 flex items-center pr-3.5 text-gray-400 hover:text-gray-600 transition-colors">
                            <svg data-password-visibility-target="eyeOpen"
                                 class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                            </svg>
                            <svg data-password-visibility-target="eyeClosed"
                                 class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                            </svg>
                        </button>
                    </div>
                    {% if errors.current_password is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.current_password }}</p>
                    {% endif %}
                </div>

                {# Nueva contraseña #}
                <div>
                    <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'profile.field.new_password'|trans({}, 'messages') }}
                    </label>
                    <input id="new_password" type="password" name="new_password"
                           autocomplete="new-password" required
                           class="block w-full rounded-xl border py-3 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.new_password is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-forest-500 focus:bg-white focus:ring-forest-500/20' }}">
                    {% if errors.new_password is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.new_password }}</p>
                    {% else %}
                        <p class="mt-1.5 text-xs text-gray-500">{{ 'profile.hint.password_policy'|trans({'%min%': 12}, 'messages') }}</p>
                    {% endif %}
                </div>

                {# Confirmar nueva contraseña #}
                <div>
                    <label for="new_password_confirm" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'profile.field.new_password_confirm'|trans({}, 'messages') }}
                    </label>
                    <input id="new_password_confirm" type="password" name="new_password_confirm"
                           autocomplete="new-password" required
                           class="block w-full rounded-xl border py-3 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.new_password_confirm is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-forest-500 focus:bg-white focus:ring-forest-500/20' }}">
                    {% if errors.new_password_confirm is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.new_password_confirm }}</p>
                    {% endif %}
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('force_password_change') }}">

                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-forest-600 hover:bg-forest-700 active:bg-forest-800
                               text-white font-semibold text-sm
                               py-3 px-4 rounded-xl transition-colors duration-150
                               focus:outline-none focus:ring-3 focus:ring-forest-500/40">
                    {{ 'force_password_change.submit'|trans({}, 'messages') }}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                    </svg>
                </button>
            </form>

            <div class="mt-6 text-center">
                <a href="{{ path('app_logout', {'_csrf_token': csrf_token('logout')}) }}"
                   class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
                    {{ 'force_password_change.logout'|trans({}, 'messages') }}
                </a>
            </div>

        </div>
    </div>

</div>
{% endblock %}
