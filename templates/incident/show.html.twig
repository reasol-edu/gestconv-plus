{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'incident.show_ref'|trans({'%number%': report.number}, 'admin') }} · {{ report.student.name.lastName }}, {{ report.student.name.firstName }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
                {% include 'components/_breadcrumb_home.html.twig' %}
                <a href="{{ path('app_incidents_index') }}" class="hover:text-forest-600 transition-colors">{{ 'incident.title'|trans({}, 'admin') }}</a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
                <span aria-current="page" class="text-gray-700 font-medium">{{ 'incident.show_ref'|trans({'%number%': report.number}, 'admin') }}</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">
                <a href="{{ path('app_students_show', {id: report.student.id}) }}"
                   class="hover:text-forest-700 transition-colors">
                    {{ report.student.name.lastName }}, {{ report.student.name.firstName }}
                </a>
            </h1>
            <p class="mt-1 text-sm text-gray-500">
                {{ report.group.name }} · {{ report.occurredAt|date('format.datetime'|trans) }}
            </p>
            <div class="mt-2">
                {% set notifyUrl = is_granted('incident_report.notify', report) and not is_viewing_past_year() ? path('app_notifications_register_report', {id: report.id}) : null %}
                {% if report.isNotified %}
                    {% set badgeClasses, badgeIcon, badgeLabel = 'bg-green-100 text-green-700', 'heroicons:check-circle', 'notification.badge.notified'|trans({}, 'notifications') %}
                {% else %}
                    {% set badgeClasses, badgeIcon, badgeLabel = 'bg-amber-100 text-amber-800', 'heroicons:bell-alert', 'notification.badge.pending'|trans({}, 'notifications') %}
                {% endif %}
                {% if notifyUrl %}
                    <a href="{{ notifyUrl }}"
                       class="inline-flex items-center gap-1.5 rounded-full {{ badgeClasses }} px-2.5 py-0.5 text-xs font-medium hover:opacity-80 transition-opacity">
                        {{ ux_icon(badgeIcon, {class: 'h-3 w-3'}) }}
                        {{ badgeLabel }}
                    </a>
                {% else %}
                    <span class="inline-flex items-center gap-1.5 rounded-full {{ badgeClasses }} px-2.5 py-0.5 text-xs font-medium">
                        {{ ux_icon(badgeIcon, {class: 'h-3 w-3'}) }}
                        {{ badgeLabel }}
                    </span>
                {% endif %}
            </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
            <a href="{{ path('app_incidents_pdf', {id: report.id}) }}" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                      hover:bg-gray-50 transition-colors shadow-xs">
                {{ ux_icon('heroicons:document-arrow-down', {class: 'h-4 w-4'}) }}
                {{ 'incident.pdf.download'|trans({}, 'admin') }}
            </a>
            {% if not report.isNotified and not report.prescribed and is_granted('incident_report.notify', report) and not is_viewing_past_year() %}
                <a href="{{ path('app_notifications_register_report', {id: report.id}) }}"
                   class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-medium text-white
                          hover:bg-forest-700 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:bell-alert', {class: 'h-4 w-4'}) }}
                    {{ 'notification.register_report.title'|trans({}, 'notifications') }}
                </a>
            {% endif %}
            {% if is_granted('incident_report.edit', report) and not is_viewing_past_year() %}
                <a href="{{ path('app_incidents_edit', {id: report.id}) }}"
                   class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:pencil-square', {class: 'h-4 w-4'}) }}
                    {{ 'ui.edit'|trans }}
                </a>
            {% endif %}
            {% if is_granted('incident_report.delete', report) and not is_viewing_past_year() %}
                <form method="post" action="{{ path('app_incidents_delete', {id: report.id}) }}"
                      class="js-confirm-form"
                      data-confirm="{{ 'incident.delete_confirm'|trans({}, 'admin')|e('html_attr') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_incident_' ~ report.id) }}">
                    <button type="submit" class="js-confirm-trigger inline-flex items-center gap-2 rounded-xl border border-red-200 bg-white px-4 py-2.5 text-sm font-medium text-red-600
                                                 hover:bg-red-50 transition-colors shadow-xs">
                        {{ ux_icon('heroicons:trash', {class: 'h-4 w-4'}) }}
                        {{ 'ui.delete'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs divide-y divide-gray-100">

        {# Metadata #}
        <div class="px-6 py-4 grid grid-cols-2 gap-4 text-sm">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'incident.col.teacher'|trans({}, 'admin') }}</p>
                <p class="text-gray-900">{{ report.registeredBy.name.lastName }}, {{ report.registeredBy.name.firstName }}</p>
            </div>
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'incident.col.occurred_at'|trans({}, 'admin') }}</p>
                <p class="text-gray-900">{{ report.occurredAt|date('format.datetime'|trans) }}</p>
            </div>
            {% if report.location %}
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">{{ 'incident.field.location'|trans({}, 'admin') }}</p>
                    <p class="text-gray-900">{{ report.location.name }}</p>
                </div>
            {% endif %}
        </div>

        {% include 'notification/_report_detail.html.twig' with { report: report } %}

    </div>

    <div>
        <h2 class="text-base font-semibold text-gray-900 mb-3">{{ 'incident.observation.title'|trans({}, 'admin') }}</h2>
        <div class="space-y-4">
            {% include 'incident/_observation_form.html.twig' with { report: report } %}
            {% include 'incident/_observation_list.html.twig' with { observations: observations } %}
        </div>
    </div>

    <div>
        <h2 class="text-base font-semibold text-gray-900 mb-3">{{ 'notification.history.title'|trans({}, 'notifications') }}</h2>
        {% include 'notification/_communication_history.html.twig' with { history: history } %}
    </div>

</div>
{% endblock %}
