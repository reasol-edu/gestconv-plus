{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'activity.new'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_absences_index') }}" class="hover:text-forest-600 transition-colors">{{ 'absence.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_absences_show', {id: absence.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ absence.startDate|date('format.date'|trans) }} — {{ absence.endDate|date('format.date'|trans) }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'activity.new'|trans({}, 'admin') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'activity.new'|trans({}, 'admin') }}</h1>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 space-y-1">
            {% for error in errors %}
                <p class="text-sm text-red-700">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_absences_activity_new', {id: absence.id}) }}" enctype="multipart/form-data" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('new_activity_' ~ absence.id) }}">

        {% include 'absence/_activity_form_fields.html.twig' %}

        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('app_absences_show', {id: absence.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                      hover:bg-gray-50 transition-colors">
                {{ 'activity.cancel'|trans({}, 'admin') }}
            </a>
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-forest-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                {{ 'activity.save'|trans({}, 'admin') }}
            </button>
        </div>
    </form>
</div>
{% endblock %}
