{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'absence.edit'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            {% include 'components/_breadcrumb_home.html.twig' %}
            <a href="{{ path('app_absences_index') }}" class="hover:text-forest-600 transition-colors">{{ 'absence.title'|trans({}, 'admin') }}</a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_absences_show', {id: absence.id}) }}" class="hover:text-forest-600 transition-colors">
                {{ absence.startDate|date('format.date'|trans) }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <span aria-current="page" class="text-gray-700 font-medium">{{ 'absence.edit'|trans({}, 'admin') }}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'absence.edit'|trans({}, 'admin') }}</h1>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 space-y-1">
            {% for error in errors %}
                <p class="text-sm text-red-700">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_absences_edit', {id: absence.id}) }}" class="space-y-6"
          data-controller="non-working-day"
          data-non-working-day-dates-value="{{ nonWorkingDayDates|default([])|json_encode }}"
          data-non-working-day-blocked-message-value="{{ 'non_working_date.selection_reverted'|trans({}, 'admin') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_absence_' ~ absence.id) }}">

        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs p-6 space-y-5">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="start_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'absence.field.start_date'|trans({}, 'admin') }} <span class="text-red-500" aria-hidden="true">*</span>
                    </label>
                    <input type="date" id="start_date" name="start_date" value="{{ formData.start_date }}" required
                           {% if errors.start_date is defined %}aria-invalid="true"{% endif %}
                           data-non-working-day-target="input"
                           data-action="change->non-working-day#check"
                           class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                                  focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                    {% if errors.start_date is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.start_date }}</p>
                    {% endif %}
                    <p data-non-working-day-target="warning" class="mt-1 text-xs text-red-600 hidden"></p>
                </div>
                <div>
                    <label for="end_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'absence.field.end_date'|trans({}, 'admin') }} <span class="text-red-500" aria-hidden="true">*</span>
                    </label>
                    <input type="date" id="end_date" name="end_date" value="{{ formData.end_date }}" required
                           {% if errors.end_date is defined %}aria-invalid="true"{% endif %}
                           data-non-working-day-target="input"
                           data-action="change->non-working-day#check"
                           class="block w-full rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900
                                  focus:border-forest-500 focus:bg-white focus:outline-none focus:ring-3 focus:ring-forest-500/20 transition-colors">
                    {% if errors.end_date is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.end_date }}</p>
                    {% endif %}
                    <p data-non-working-day-target="warning" class="mt-1 text-xs text-red-600 hidden"></p>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('app_absences_show', {id: absence.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                      hover:bg-gray-50 transition-colors">
                {{ 'absence.cancel'|trans({}, 'admin') }}
            </a>
            <button type="submit"
                    class="inline-flex items-center gap-2 rounded-xl bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-forest-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:check', {class: 'h-4 w-4'}) }}
                {{ 'absence.save'|trans({}, 'admin') }}
            </button>
        </div>
    </form>
</div>
{% endblock %}
